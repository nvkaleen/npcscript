-- Dragging
local function makeDraggable(frame, handle)
    local dragging, delta = false, Vector2.new(0, 0)
    track(handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local mp = UIS:GetMouseLocation()
            local fp = frame.AbsolutePosition
            delta = Vector2.new(mp.X - fp.X, mp.Y - fp.Y)
        end
    end))
    track(UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local mp = UIS:GetMouseLocation()
            frame.Position = UDim2.new(0, mp.X - delta.X, 0, mp.Y - delta.Y)
        end
    end))
    track(UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))
end
makeDraggable(main, top)

