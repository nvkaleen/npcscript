    panTitle.TextSize = 10; panTitle.TextXAlignment = Enum.TextXAlignment.Left
    panTitle.ZIndex = 82; panTitle.Parent = panTop

    local panClose = Instance.new("TextButton")
    panClose.Size = UDim2.new(0, 16, 0, 16); panClose.Position = UDim2.new(1, -18, 0.5, -8)
    panClose.BackgroundColor3 = Color3.fromRGB(128, 15, 15); panClose.Text = "✕"
    panClose.Font = Enum.Font.GothamBold; panClose.TextColor3 = Color3.new(1,1,1)
    panClose.TextSize = 8; panClose.ZIndex = 83; panClose.Parent = panTop
    Instance.new("UICorner", panClose).CornerRadius = UDim.new(0, 3)

    local panRefresh = Instance.new("TextButton")
    panRefresh.Size = UDim2.new(0, 16, 0, 16); panRefresh.Position = UDim2.new(1, -38, 0.5, -8)
    panRefresh.BackgroundColor3 = accentColor:Lerp(Color3.new(1,1,1), 0.2); panRefresh.Text = "🔄"
    panRefresh.Font = Enum.Font.GothamBold; panRefresh.TextColor3 = Color3.new(1,1,1)
    panRefresh.TextSize = 8; panRefresh.ZIndex = 83; panRefresh.Parent = panTop
    Instance.new("UICorner", panRefresh).CornerRadius = UDim.new(0, 3)

    if extraBtn then
        local pe = Instance.new("TextButton")
        pe.Size = UDim2.new(0, 16, 0, 16); pe.Position = UDim2.new(1, -58, 0.5, -8)
        pe.BackgroundColor3 = Color3.fromRGB(40, 40, 65); pe.Text = "⚙"
