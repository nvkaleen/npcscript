    deselAll.Size = UDim2.new(0, 62, 0, 16); deselAll.Position = UDim2.new(0, 66, 0, 28)
    deselAll.BackgroundColor3 = Color3.fromRGB(95, 25, 25); deselAll.Text = "✗ None"
    deselAll.Font = Enum.Font.GothamBold; deselAll.TextColor3 = Color3.new(1,1,1)
    deselAll.TextSize = 8; deselAll.ZIndex = 82; deselAll.Parent = panel
    Instance.new("UICorner", deselAll).CornerRadius = UDim.new(0, 3)

    local cntLbl = Instance.new("TextLabel")
    cntLbl.Size = UDim2.new(0, 80, 0, 16); cntLbl.Position = UDim2.new(1, -84, 0, 28)
    cntLbl.BackgroundTransparency = 1; cntLbl.Text = "0"
    cntLbl.Font = Enum.Font.Gotham; cntLbl.TextColor3 = Color3.fromRGB(148, 148, 175)
    cntLbl.TextSize = 8; cntLbl.TextXAlignment = Enum.TextXAlignment.Right
    cntLbl.ZIndex = 82; cntLbl.Parent = panel

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, -8, 1, -50); scroll.Position = UDim2.new(0, 4, 0, 48)
    scroll.BackgroundColor3 = Color3.fromRGB(8, 8, 14); scroll.BackgroundTransparency = 0.2
    scroll.BorderSizePixel = 0; scroll.ScrollBarThickness = 3; scroll.ScrollBarImageColor3 = accentColor
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0); scroll.ElasticBehavior = Enum.ElasticBehavior.Never
    scroll.ZIndex = 81; scroll.Parent = panel; Instance.new("UICorner", scroll).CornerRadius = UDim.new(0, 4)

    local RH, RP = 22, 2
    local rows = {}

    local function updateCount()
        local t, s = 0, 0
        for _, d in pairs(rows) do t = t + 1; if d.en then s = s + 1 end end
        cntLbl.Text = s .. "/" .. t
    end

    local function addRow(dispName, key, idx)
        local rw = Instance.new("Frame")
        rw.Size = UDim2.new(1, -2, 0, RH); rw.Position = UDim2.new(0, 1, 0, 1 + (idx-1)*(RH+RP))
        rw.BackgroundColor3 = Color3.fromRGB(18, 18, 28); rw.BorderSizePixel = 0
        rw.ZIndex = 82; rw.Parent = scroll; Instance.new("UICorner", rw).CornerRadius = UDim.new(0, 3)

        local nl = Instance.new("TextLabel")
        nl.Size = UDim2.new(1, -42, 1, 0); nl.Position = UDim2.new(0, 3, 0, 0)
        nl.BackgroundTransparency = 1; nl.Text = dispName; nl.Font = Enum.Font.Gotham
        nl.TextColor3 = Color3.fromRGB(188, 188, 208); nl.TextSize = 8
        nl.TextXAlignment = Enum.TextXAlignment.Left; nl.TextTruncate = Enum.TextTruncate.AtEnd
        nl.ZIndex = 83; nl.Parent = rw

        local en = true
        if filterTable[key] ~= nil then en = filterTable[key] end

        local tb = Instance.new("TextButton")
        tb.Size = UDim2.new(0, 36, 0, 14); tb.Position = UDim2.new(1, -40, 0.5, -7)
        tb.BackgroundColor3 = en and Color3.fromRGB(25, 108, 55) or Color3.fromRGB(75, 20, 20)
        tb.Text = en and "✓" or "✗"
        tb.Font = Enum.Font.GothamBold; tb.TextColor3 = Color3.new(1,1,1)
        tb.TextSize = 8; tb.ZIndex = 84; tb.Parent = rw
        Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 3)

        local data = {row=rw, tb=tb, en=en, key=key}
        rows[key] = data
        filterTable[key] = en

        track(tb.MouseButton1Click:Connect(function()
            data.en = not data.en; filterTable[data.key] = data.en
            tb.Text = data.en and "✓" or "✗"
            tb.BackgroundColor3 = data.en and Color3.fromRGB(25, 108, 55) or Color3.fromRGB(75, 20, 20)
            updateCount()
        end))
    end

    local function refresh()
        for _, d in pairs(rows) do if d.row and d.row.Parent then d.row:Destroy() end end
        rows = {}
        local npcs = allNPCs()
        local named = displayNames(npcs)
        local seen, uniq = {}, {}
        for _, item in ipairs(named) do
            local k = npcKey(item.e.model)
            if not seen[k] then seen[k] = true; table.insert(uniq, {d=item.name, k=k}) end
        end
        table.sort(uniq, function(a, b) return a.d:lower() < b.d:lower() end)
        for i, n in ipairs(uniq) do addRow(n.d, n.k, i) end
        scroll.CanvasSize = UDim2.new(0, 0, 0, 1 + #uniq * (RH + RP))
        updateCount()
    end

    track(selAll.MouseButton1Click:Connect(function()
        for k, d in pairs(rows) do d.en = true; filterTable[k] = true; d.tb.Text = "✓"; d.tb.BackgroundColor3 = Color3.fromRGB(25, 108, 55) end
        updateCount()
    end))
    track(deselAll.MouseButton1Click:Connect(function()
        for k, d in pairs(rows) do d.en = false; filterTable[k] = false; d.tb.Text = "✗"; d.tb.BackgroundColor3 = Color3.fromRGB(75, 20, 20) end
        updateCount()
    end))
    track(panRefresh.MouseButton1Click:Connect(refresh))
    track(panClose.MouseButton1Click:Connect(function() panel.Visible = false end))
    return panel, refresh
end

