    panTop.BorderSizePixel = 0; panTop.ZIndex = 81; panTop.Parent = panel
    Instance.new("UICorner", panTop).CornerRadius = UDim.new(0, 10)
    local pp = Instance.new("Frame"); pp.Size = UDim2.new(1,0,0,8); pp.Position = UDim2.new(0,0,1,-8)
