local function npcsInRange(range)
    local myH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myH then return {} end
    local pos = myH.Position
    local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then
                local ok, dist = pcall(function() return (hrp.Position - pos).Magnitude end)
                if ok and dist <= range then
                    table.insert(list, {hum=d, hrp=hrp, model=d.Parent})
                end
            end
        end
    end
    return list
end

