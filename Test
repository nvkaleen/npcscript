local function npcsInRange(r)
    local mH=player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not mH then return {} end
    local mp=mH.Position; local l={}
    for _,d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
