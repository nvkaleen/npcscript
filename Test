local function unanchorAll() for m,_ in pairs(anchoredNPCs) do unanchor(m) end; anchoredNPCs={} end

local function letMove(m,d)
    pcall(function() for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then p.Anchored=false end end
        d.hum.PlatformStand=false; d.hum.WalkSpeed=d.oW or 16; d.hum.JumpPower=d.oJ or 50; d.hum.JumpHeight=d.oJH or 7.2
        for _,j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled=true end end
        for _,o in ipairs(m:GetDescendants()) do if o:IsA("BallSocketConstraint") then o:Destroy() end end
        d.hum:ChangeState(Enum.HumanoidStateType.GettingUp); task.wait(0.1); d.hum:ChangeState(Enum.HumanoidStateType.Running)
        if d.hrp then d.hrp.Velocity=Vector3.new(0,5,0) end end) end
