track(mouse.Button1Down:Connect(function()
    local target = mouse.Target; if not target then return end

    if anchorMode and target:IsA("BasePart") then target.Anchored = not target.Anchored; return end

    -- Teleport destination
    if S.teleportClick and teleportTarget then
        local dest = mouse.Hit.Position
        pcall(function()
            local hrp = teleportTarget:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Anchored = false; hrp.CFrame = CFrame.new(dest + Vector3.new(0,3,0)); hrp.Velocity = Vector3.new(0,0,0) end
        end)
        teleportTarget = nil
        btns2["📍 Teleport NPC"].Text = "⏹ 📍 Teleport NPC: ON"
        return
    end

    local md = target:FindFirstAncestorOfClass("Model"); if not md then return end
    local hum = md:FindFirstChildOfClass("Humanoid")
    local hrp = md:FindFirstChild("HumanoidRootPart")
    local isNPC = hum and not Players:GetPlayerFromCharacter(md); if not isNPC then return end

    if S.viewNPC then
        workspace.CurrentCamera.CameraSubject = hum; viewingNPC = true; viewedHum = hum
        uvBtn.Visible = true; uvBtn.Text = "👁 " .. md.Name
    elseif S.killClick then hum.Health = 0
    elseif S.flingClick and hrp then hrp.Velocity = Vector3.new(math.random()*2-1, 0.5, math.random()*2-1).Unit * flingStr
    elseif S.deleteClick then trackDeleted(md); pcall(function() md:Destroy() end); refreshRespawn()
    elseif S.bringClick then
        local mH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if mH and hrp then bringNPC({hum=hum, hrp=hrp, model=md}, mH.CFrame * CFrame.new(0,0,-5), md.Name) end
    elseif S.ragdollClick then ragdollNPC(md)
    elseif S.freezeClick then if isFrozen(md) then unfreezeNPC(md) else freezeNPC(md) end
    elseif S.teleportClick then teleportTarget = md; btns2["📍 Teleport NPC"].Text = "📍 Click dest..."
    elseif S.followClick then if followNPCs[md] then followNPCs[md] = nil else followNPCs[md] = true; startFollow() end
    elseif S.speedClick then pcall(function() hum.WalkSpeed = npcSpeed end)
    elseif S.healthClick then pcall(function() hum.MaxHealth = npcHealth; hum.Health = npcHealth end)
    elseif S.sizeClick then resizeNPC(md, sizeX, sizeY, sizeZ)
    elseif S.invisClick then
        local vis = true
        pcall(function() for _, p in ipairs(md:GetDescendants()) do if p:IsA("BasePart") and p.Transparency >= 0.9 then vis = false; break end end end)
        pcall(function() for _, p in ipairs(md:GetDescendants()) do
            if p:IsA("BasePart") then p.Transparency = vis and 1 or 0 end
            if p:IsA("Decal") or p:IsA("Texture") then p.Transparency = vis and 1 or 0 end end end)
    elseif S.infoClick then showInfoPanel(md)
    elseif S.respawnClick then switchTab(6); refreshRespawn()
    end
end))

