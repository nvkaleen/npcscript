local respawnRows = {}
local function refreshRespawn()
    for _, r in ipairs(respawnRows) do if r and r.Parent then r:Destroy() end end
    respawnRows = {}
    rNone.Visible = (#deletedNPCs == 0)
    for i, data in ipairs(deletedNPCs) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -4, 0, 24); row.Position = UDim2.new(0, 2, 0, 20 + (i-1) * 28)
        row.BackgroundColor3 = Color3.fromRGB(18, 26, 18); row.BorderSizePixel = 0
        row.ZIndex = 4; row.Parent = s6; Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)

        local nL = Instance.new("TextLabel")
        nL.Size = UDim2.new(1, -58, 1, 0); nL.Position = UDim2.new(0, 4, 0, 0)
        nL.BackgroundTransparency = 1; nL.Text = "💀 " .. data.name
        nL.Font = Enum.Font.GothamBold; nL.TextColor3 = Color3.fromRGB(88, 205, 128)
        nL.TextSize = 8; nL.TextXAlignment = Enum.TextXAlignment.Left
        nL.TextTruncate = Enum.TextTruncate.AtEnd; nL.ZIndex = 5; nL.Parent = row

        local rBtn = Instance.new("TextButton")
        rBtn.Size = UDim2.new(0, 50, 0, 16); rBtn.Position = UDim2.new(1, -54, 0.5, -8)
        rBtn.BackgroundColor3 = Color3.fromRGB(38, 145, 75); rBtn.Text = "🔄 Spawn"
        rBtn.Font = Enum.Font.GothamBold; rBtn.TextColor3 = Color3.new(1,1,1)
        rBtn.TextSize = 7; rBtn.ZIndex = 6; rBtn.Parent = row
        Instance.new("UICorner", rBtn).CornerRadius = UDim.new(0, 3)

        local idx = i
        track(rBtn.MouseButton1Click:Connect(function()
            local d = deletedNPCs[idx]
            if d and d.clone then
                pcall(function()
                    local n = d.clone:Clone()
                    n.Parent = workspace
                    local hrp = n:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.CFrame = d.cf end
                end)
                table.remove(deletedNPCs, idx)
                refreshRespawn()
            end
        end))
        table.insert(respawnRows, row)
    end
    s6.CanvasSize = UDim2.new(0, 0, 0, 20 + #deletedNPCs * 28 + 4)
end

