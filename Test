local function ragdoll(m)
    local h=m:FindFirstChildOfClass("Humanoid"); if not h then return end
    pcall(function() h:ChangeState(Enum.HumanoidStateType.Physics) end); pcall(function() h.PlatformStand=true end)
    pcall(function() for _,j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") and not j:GetAttribute("_rd") then j:SetAttribute("_rd",true)
        local a0=Instance.new("Attachment"); a0.CFrame=j.C0; a0.Parent=j.Part0; local a1=Instance.new("Attachment"); a1.CFrame=j.C1; a1.Parent=j.Part1
        local b=Instance.new("BallSocketConstraint"); b.Attachment0=a0; b.Attachment1=a1; b.LimitsEnabled=true; b.UpperAngle=45; b.Parent=j.Parent; j.Enabled=false end end end)
    local hr=m:FindFirstChild("HumanoidRootPart"); if hr then hr.Velocity=hr.Velocity+Vector3.new(0,30,0) end end

local function nuke(m,hr,hum)
    pcall(function() for _,o in ipairs(m:GetDescendants()) do if o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") or o:IsA("BodyForce") or o:IsA("LinearVelocity") or o:IsA("AlignPosition") or o:IsA("AlignOrientation") or o:IsA("VectorForce") then o:Destroy() end end end)
    pcall(function() for _,o in ipairs(m:GetDescendants()) do if o:IsA("Script") or o:IsA("LocalScript") then pcall(function() o.Disabled=true end); pcall(function() o:Destroy() end) end end end)
    pcall(function() for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.Velocity=Vector3.new(0,0,0) end); pcall(function() p.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end end end)
    local oW,oJ,oJH=16,50,7.2; pcall(function() oW=hum.WalkSpeed end); pcall(function() oJ=hum.JumpPower end)
    pcall(function() hum.WalkSpeed=0; hum.JumpPower=0; hum.JumpHeight=0 end); pcall(function() hum.PlatformStand=true end); pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end); pcall(function() hr.Anchored=true end)
    return oW,oJ,oJH end

