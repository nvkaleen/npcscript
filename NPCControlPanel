local function refreshInfoList()
    for _, child in ipairs(s7:GetChildren()) do
        if child:IsA("Frame") and child.Name == "InfoRow" then child:Destroy() end
    end
    local npcs = allNPCRoots()
    local named = buildDisplayNames(npcs)
    local seen, uniq = {}, {}
    for _, item in ipairs(named) do
        local k = getNPCKey(item.e.model)
        if not seen[k] then seen[k] = true; table.insert(uniq, {e=item.e, d=item.d}) end
    end
    table.sort(uniq, function(a, b) return a.d:lower() < b.d:lower() end)
    for i, npc in ipairs(uniq) do
        local row = Instance.new("Frame"); row.Name = "InfoRow"
        row.Size = UDim2.new(1, -4, 0, 26); row.Position = UDim2.new(0, 2, 0, 20 + (i-1) * 30)
        row.BackgroundColor3 = Color3.fromRGB(16, 20, 28); row.BorderSizePixel = 0
        row.ZIndex = 4; row.Parent = s7; Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)

        local nL = Instance.new("TextLabel")
        nL.Size = UDim2.new(0.35, 0, 1, 0); nL.Position = UDim2.new(0, 3, 0, 0)
        nL.BackgroundTransparency = 1; nL.Text = npc.d; nL.Font = Enum.Font.GothamBold
        nL.TextColor3 = Color3.fromRGB(195, 215, 235); nL.TextSize = 7
        nL.TextXAlignment = Enum.TextXAlignment.Left; nL.TextTruncate = Enum.TextTruncate.AtEnd
        nL.ZIndex = 5; nL.Parent = row

        local infoLbl = Instance.new("TextLabel")
        infoLbl.Size = UDim2.new(0.65, -3, 1, 0); infoLbl.Position = UDim2.new(0.35, 0, 0, 0)
        infoLbl.BackgroundTransparency = 1; infoLbl.Font = Enum.Font.Gotham
        infoLbl.TextColor3 = Color3.fromRGB(148, 178, 198); infoLbl.TextSize = 7
        infoLbl.TextXAlignment = Enum.TextXAlignment.Left; infoLbl.ZIndex = 5; infoLbl.Parent = row

        local target = npc
        local conn; conn = RS.RenderStepped:Connect(function()
            if not target.e.model.Parent then pcall(function() conn:Disconnect() end); return end
            pcall(function()
                local hum = target.e.hum; local hrp = target.e.hrp
                local myH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local dist = myH and math.floor((hrp.Position - myH.Position).Magnitude) or "?"
                infoLbl.Text = string.format("HP:%d/%d Spd:%d D:%s", math.floor(hum.Health), math.floor(hum.MaxHealth), math.floor(hum.WalkSpeed), tostring(dist))
            end)
        end)
    end
    s7.CanvasSize = UDim2.new(0, 0, 0, 20 + #uniq * 30 + 5)
end
