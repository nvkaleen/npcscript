-- BRING ALL — nuclear per-NPC locking
track(buttons["Bring All NPCs"].MouseButton1Click:Connect(function()
    local mH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not mH then return end
    local btn = buttons["Bring All NPCs"]
    btn.BackgroundColor3 = Color3.fromRGB(80,80,80)
    task.spawn(function()
        -- Get filtered NPCs
        local filtered = {}
        for _,e in ipairs(allNPCRoots()) do
            local k = getNPCKey(e.model)
            if next(bringFilter)==nil or bringFilter[k]~=false then table.insert(filtered, e) end
        end
        -- Calculate target positions
        local targets = {}
        for i,e in ipairs(filtered) do
            local angle = (i/math.max(1,#filtered))*math.pi*2
            targets[i] = mH.CFrame * CFrame.new(math.cos(angle)*4, 0, math.sin(angle)*4)
        end
        -- Per-NPC retry until locked
        for att = 1, bringAttempts do
            btn.Text = "Locking... ("..att.."/"..bringAttempts..")"
            local allLocked = true
            for i,e in ipairs(filtered) do
                -- Check if NPC still exists
                local exists = pcall(function() local _ = e.hrp.Position end)
                if exists and targets[i] then
                    if not isNPCAtPos(e.hrp, targets[i], 2) then
                        allLocked = false
                        bringNPCToPos(e, targets[i])
                    end
                end
            end
            if allLocked then break end
            if att < bringAttempts then task.wait(0.05) end
        end
        -- Final nuke pass — make sure everything is locked
        for i,e in ipairs(filtered) do
            local exists = pcall(function() local _ = e.hrp.Position end)
            if exists and targets[i] then
                bringNPCToPos(e, targets[i])
            end
        end
        btn.Text = "Bring All NPCs"; btn.BackgroundColor3 = Color3.fromRGB(0,139,139)
    end)
end))

