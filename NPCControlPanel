    local function cRow(dn,ky,ix) local rw=Instance.new("Frame"); rw.Size=UDim2.new(1,-10,0,RH); rw.Position=UDim2.new(0,5,0,5+(ix-1)*(RH+RP)); rw.BackgroundColor3=Color3.fromRGB(28,28,40); rw.BorderSizePixel=0; rw.ZIndex=82; rw.Parent=psc; Instance.new("UICorner",rw).CornerRadius=UDim.new(0,5)
        local nl=Instance.new("TextLabel"); nl.Size=UDim2.new(1,-80,1,0); nl.Position=UDim2.new(0,10,0,0); nl.BackgroundTransparency=1; nl.Text=dn; nl.Font=Enum.Font.Gotham; nl.TextColor3=Color3.fromRGB(220,220,240); nl.TextSize=12; nl.TextXAlignment=Enum.TextXAlignment.Left; nl.TextTruncate=Enum.TextTruncate.AtEnd; nl.ZIndex=83; nl.Parent=rw
        local en=true; if cfg.filterTable[ky]~=nil then en=cfg.filterTable[ky] end
        local tb2=Instance.new("TextButton"); tb2.Size=UDim2.new(0,64,0,24); tb2.Position=UDim2.new(1,-70,0.5,-12); tb2.BackgroundColor3=en and Color3.fromRGB(40,140,80) or Color3.fromRGB(100,35,35); tb2.Text=en and ("✓ "..cfg.onLabel) or ("✗ "..cfg.offLabel); tb2.Font=Enum.Font.GothamBold; tb2.TextColor3=Color3.new(1,1,1); tb2.TextSize=10; tb2.ZIndex=84; tb2.Parent=rw; Instance.new("UICorner",tb2).CornerRadius=UDim.new(0,5)
        local data={row=rw,toggleBtn=tb2,enabled=en,key=ky}; rows[ky]=data; cfg.filterTable[ky]=en
        track(tb2.MouseButton1Click:Connect(function() data.enabled=not data.enabled; cfg.filterTable[data.key]=data.enabled
            if data.enabled then tb2.Text="✓ "..cfg.onLabel; tb2.BackgroundColor3=Color3.fromRGB(40,140,80); TweenService:Create(rw,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(28,28,40)}):Play()
            else tb2.Text="✗ "..cfg.offLabel; tb2.BackgroundColor3=Color3.fromRGB(100,35,35); TweenService:Create(rw,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(35,20,20)}):Play() end; uc() end))
        rw.MouseEnter:Connect(function() TweenService:Create(rw,TweenInfo.new(0.1),{BackgroundColor3=data.enabled and Color3.fromRGB(36,36,55) or Color3.fromRGB(45,25,25)}):Play() end)
        rw.MouseLeave:Connect(function() TweenService:Create(rw,TweenInfo.new(0.1),{BackgroundColor3=data.enabled and Color3.fromRGB(28,28,40) or Color3.fromRGB(35,20,20)}):Play() end) end
    local function refresh() for _,d in pairs(rows) do if d.row and d.row.Parent then d.row:Destroy() end end; rows={}
        local npcs=allNPCRoots(); local named=buildDisplayNames(npcs); local seen={}; local uniq={}
        for _,item in ipairs(named) do local k=getNPCKey(item.e.model); if not seen[k] then seen[k]=true; table.insert(uniq,{display=item.display,key=k}) end end
        table.sort(uniq,function(a,b) return a.display:lower()<b.display:lower() end)
        for i,n in ipairs(uniq) do cRow(n.display,n.key,i) end; psc.CanvasSize=UDim2.new(0,0,0,5+#uniq*(RH+RP)); uc() end
    track(sa.MouseButton1Click:Connect(function() for k,d in pairs(rows) do d.enabled=true; cfg.filterTable[k]=true; d.toggleBtn.Text="✓ "..cfg.onLabel; d.toggleBtn.BackgroundColor3=Color3.fromRGB(40,140,80); d.row.BackgroundColor3=Color3.fromRGB(28,28,40) end; uc() end))
    track(da.MouseButton1Click:Connect(function() for k,d in pairs(rows) do d.enabled=false; cfg.filterTable[k]=false; d.toggleBtn.Text="✗ "..cfg.offLabel; d.toggleBtn.BackgroundColor3=Color3.fromRGB(100,35,35); d.row.BackgroundColor3=Color3.fromRGB(35,20,20) end; uc() end))
    track(pr.MouseButton1Click:Connect(refresh)); track(pcl.MouseButton1Click:Connect(function() p.Visible=false end))
    return p, refresh
end

