local function resetStates()  
	loopEpoch = loopEpoch + 1  
	workspace.CurrentCamera.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	for k in pairs(states) do states[k] = false end  
	killBtn.BackgroundColor3 = Color3.fromRGB(46, 139, 87)  
	pushBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 180)  
	local offColor = Color3.fromRGB(105, 105, 105)
	nkBtn.BackgroundColor3, freezeBtn.BackgroundColor3, killClickBtn.BackgroundColor3 = offColor, offColor, offColor
	flingBtn.BackgroundColor3, viewBtn.BackgroundColor3, objectDeleteBtn.BackgroundColor3 = offColor, offColor, offColor
	autoFlingBtn.BackgroundColor3 = offColor
end  
  
local function flingNPC(character)
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp and not hrp.Anchored then
		hrp.Velocity = Vector3.new(math.random(-100, 100)/100, 1, math.random(-100, 100)/100).Unit * flingStrength
	end
end

local function flingAll()
	for _, d in pairs(workspace:GetDescendants()) do
		if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then flingNPC(d.Parent) end
	end
end

track(mouse.Button1Down:Connect(function()  
	local target = mouse.Target  
	if not target then return end  
	local model = target:FindFirstAncestorOfClass("Model")  
	local hum = model and model:FindFirstChildOfClass("Humanoid")  
	local isNPC = hum and not Players:GetPlayerFromCharacter(model)  
  
	if states.nk and isNPC then model:Destroy()  
	elseif states.freeze and target:IsA("BasePart") then target.Anchored = not target.Anchored  
	elseif states.killClick and hum then hum.Health = 0  
	elseif states.fling and isNPC then flingNPC(model)
	elseif states.viewNPC and isNPC then workspace.CurrentCamera.CameraSubject = hum
	elseif states.objDel then target:Destroy() end  
	if anchorActive and target:IsA("BasePart") then target.Anchored = not target.Anchored end  
end))  
  
local function toggleMode(modeName, btn, label)  
	local current = states[modeName]  
	resetStates()  
	states[modeName] = not current  
	btn.BackgroundColor3 = states[modeName] and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(105, 105, 105)  
end  
  
track(killBtn.MouseButton1Click:Connect(function()  
	states.killNPCs = not states.killNPCs  
	killBtn.BackgroundColor3 = states.killNPCs and Color3.fromRGB(178, 34, 34) or Color3.fromRGB(46, 139, 87)  
	if states.killNPCs then  
		task.spawn(function()  
			local myEpoch = loopEpoch  
			while states.killNPCs and myEpoch == loopEpoch do  
				for _, d in pairs(workspace:GetDescendants()) do  
					if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then d.Health = 0 end  
				end  
				task.wait(0.5)  
			end  
		end)  
	end  
end))  
  
track(pushBtn.MouseButton1Click:Connect(function()  
	states.pushNPCs = not states.pushNPCs  
	pushBtn.BackgroundColor3 = states.pushNPCs and Color3.fromRGB(178, 34, 34) or Color3.fromRGB(70, 130, 180)  
	if states.pushNPCs then  
		task.spawn(function()  
			local myEpoch = loopEpoch  
			while states.pushNPCs and myEpoch == loopEpoch do  
				local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")  
				if hrp then  
					for _, d in pairs(workspace:GetDescendants()) do  
						if d:IsA("Humanoid") and d.Parent ~= player.Character and not Players:GetPlayerFromCharacter(d.Parent) then  
							local tHrp = d.Parent:FindFirstChild("HumanoidRootPart")  
							if tHrp and (tHrp.Position - hrp.Position).Magnitude <= pushRange then  
								tHrp.Velocity = (tHrp.Position - hrp.Position).Unit * pushStrength + Vector3.new(0, 20, 0)  
							end  
						end  
					end  
				end  
				task.wait(0.1)  
			end  
		end)  
	end  
end))  

