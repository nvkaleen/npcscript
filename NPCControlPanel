local function ragdollNPC(m) local h=m:FindFirstChildOfClass("Humanoid"); if not h then return end
    pcall(function() h:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() h:ChangeState(Enum.HumanoidStateType.Ragdoll) end)
    pcall(function() h.PlatformStand=true end)
    pcall(function() for _,j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") and not j:GetAttribute("_r") then j:SetAttribute("_r",true)
        local a0=Instance.new("Attachment"); a0.CFrame=j.C0; a0.Parent=j.Part0
        local a1=Instance.new("Attachment"); a1.CFrame=j.C1; a1.Parent=j.Part1
        local b=Instance.new("BallSocketConstraint"); b.Attachment0=a0; b.Attachment1=a1; b.LimitsEnabled=true; b.TwistLimitsEnabled=true; b.UpperAngle=45; b.TwistLowerAngle=-45; b.TwistUpperAngle=45; b.Parent=j.Parent; j.Enabled=false end end end)
    local hrp=m:FindFirstChild("HumanoidRootPart"); if hrp then hrp.Velocity=hrp.Velocity+Vector3.new(0,30,0) end end

local function nukeNPCMovement(m,hrp,hum)
    pcall(function() for _,o in ipairs(m:GetDescendants()) do
        if o:IsA("BodyVelocity")or o:IsA("BodyPosition")or o:IsA("BodyGyro")or o:IsA("BodyForce")or o:IsA("BodyThrust")or o:IsA("BodyAngularVelocity")or o:IsA("LinearVelocity")or o:IsA("AlignPosition")or o:IsA("AlignOrientation")or o:IsA("VectorForce")or o:IsA("LineForce")or o:IsA("Torque") then o:Destroy() end end end)
    pcall(function() for _,o in ipairs(m:GetDescendants()) do if o:IsA("Script")or o:IsA("LocalScript")or o:IsA("ModuleScript") then pcall(function() o.Disabled=true end); pcall(function() o:Destroy() end) end end end)
    pcall(function() for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.Velocity=Vector3.new(0,0,0) end); pcall(function() p.AssemblyLinearVelocity=Vector3.new(0,0,0) end) end end end)
    local oWS,oJP,oJH=16,50,7.2
    pcall(function() oWS=hum.WalkSpeed end); pcall(function() oJP=hum.JumpPower end); pcall(function() oJH=hum.JumpHeight end)
    pcall(function() hum.WalkSpeed=0; hum.JumpPower=0; hum.JumpHeight=0 end)
    pcall(function() hum.PlatformStand=true end); pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hrp.Anchored=true end); return oWS,oJP,oJH end

local refreshAnchoredList; local refreshDeletedList

local function bringNPCToPos(e,tc,dn)
    local oWS,oJP,oJH=16,50,7.2
    pcall(function() e.hrp.Anchored=false; e.hrp.CFrame=tc; oWS,oJP,oJH=nukeNPCMovement(e.model,e.hrp,e.hum) end)
    if not anchoredNPCs[e.model] then anchoredNPCs[e.model]={hrp=e.hrp,hum=e.hum,name=dn or e.model.Name,origWS=oWS,origJP=oJP,origJH=oJH} end end

local function isNPCAtPos(hrp,tc,th) local ok,dist=pcall(function() return (hrp.Position-tc.Position).Magnitude end); if ok then return dist<=(th or 2) end; return false end

local function unanchorNPC(m) local d=anchoredNPCs[m]; if not d then return end
    pcall(function() d.hrp.Anchored=false; d.hum.PlatformStand=false; d.hum.WalkSpeed=d.origWS or 16; d.hum.JumpPower=d.origJP or 50; d.hum.JumpHeight=d.origJH or 7.2; pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end); anchoredNPCs[m]=nil end
local function unanchorAllNPCs() for m,_ in pairs(anchoredNPCs) do unanchorNPC(m) end; anchoredNPCs={} end

local function letNPCMove(m,d)
    pcall(function()
        for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then p.Anchored=false end end
        d.hum.PlatformStand=false; d.hum.WalkSpeed=d.origWS or 16; d.hum.JumpPower=d.origJP or 50; d.hum.JumpHeight=d.origJH or 7.2
        for _,j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled=true end end
        for _,o in ipairs(m:GetDescendants()) do if o:IsA("BallSocketConstraint") then pcall(function() o:Destroy() end) end end
        pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1); pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if d.hrp then d.hrp.Velocity=Vector3.new(0,5,0) end end) end
local function letAllNPCsMove() local c=0; for m,d in pairs(anchoredNPCs) do local ex=pcall(function() local _=d.hrp.Position end); if ex and m.Parent then letNPCMove(m,d); c=c+1 end end; anchoredNPCs={}; return c end

local function freezeNPC(m) local hrp=m:FindFirstChild("HumanoidRootPart"); local hum=m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored=true; hrp.Velocity=Vector3.new(0,0,0) end) end; if hum then pcall(function() hum.WalkSpeed=0; hum.JumpPower=0 end) end end
local function unfreezeNPC(m) local hrp=m:FindFirstChild("HumanoidRootPart"); local hum=m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored=false end) end; if hum then pcall(function() hum.WalkSpeed=16; hum.JumpPower=50 end) end end
local function isNPCFrozen(m) local hrp=m:FindFirstChild("HumanoidRootPart"); if hrp then local ok,v=pcall(function() return hrp.Anchored end); if ok then return v end end; return false end

local function startFollowLoop() if followLoopActive then return end; followLoopActive=true
    task.spawn(function() local ep=loopEpoch; while followLoopActive and ep==loopEpoch do
        local mH=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if mH then for m,_ in pairs(followingNPCs) do pcall(function() if m.Parent then local hrp=m:FindFirstChild("HumanoidRootPart"); local hum=m:FindFirstChildOfClass("Humanoid")
            if hrp and hum then local dir=(mH.Position-hrp.Position); local dist=dir.Magnitude
                if dist>5 then hrp.CFrame=hrp.CFrame+dir.Unit*math.min(hum.WalkSpeed*0.03,dist-3); hrp.CFrame=CFrame.lookAt(hrp.Position,Vector3.new(mH.Position.X,hrp.Position.Y,mH.Position.Z)) end end
            else followingNPCs[m]=nil end end) end end; task.wait(0.03) end end) end

local function applyNPCSize(m,sx,sy,sz)
    pcall(function() for _,p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.Size=Vector3.new(p.Size.X*sx,p.Size.Y*sy,p.Size.Z*sz) end) end
        for _,mesh in ipairs(m:GetDescendants()) do if mesh:IsA("SpecialMesh")or mesh:IsA("BlockMesh")or mesh:IsA("CylinderMesh") then pcall(function() mesh.Scale=Vector3.new(mesh.Scale.X*sx,mesh.Scale.Y*sy,mesh.Scale.Z*sz) end) end end end) end

local function trackDeletedNPC(m) local hrp=m:FindFirstChild("HumanoidRootPart"); local cf=hrp and hrp.CFrame or CFrame.new(0,5,0)
    local pp=m.Parent and m.Parent:GetFullName() or "Workspace"
    local ok,clone=pcall(function() return m:Clone() end)
    table.insert(deletedNPCs,{name=m.Name,parentPath=pp,cframe=cf,clone=ok and clone or nil,time=os.clock()}) end

-- NAME TAG SYSTEM
local function createNameTag(model)
    if nameTagBillboards[model] then return end
    local head = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
    if not head then return end
    local bb = Instance.new("BillboardGui")
    bb.Name = "NPCNameTag"; bb.Size = UDim2.new(0,200,0,30); bb.StudsOffset = Vector3.new(0,3,0)
    bb.AlwaysOnTop = true; bb.Adornee = head; bb.Parent = head
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1
    lbl.Text = model.Name; lbl.Font = Enum.Font.GothamBold; lbl.TextColor3 = Color3.fromRGB(255,255,200)
    lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0); lbl.TextStrokeTransparency = 0.3
    lbl.TextScaled = true; lbl.Parent = bb
    nameTagBillboards[model] = bb
end

local function removeAllNameTags()
    for m,bg in pairs(nameTagBillboards) do pcall(function() bg:Destroy() end) end
    nameTagBillboards = {}
end

local function refreshNameTags()
    if not nameTagActive then return end
    for _,e in ipairs(allNPCRoots()) do createNameTag(e.model) end
    -- Clean dead tags
    for m,bg in pairs(nameTagBillboards) do if not m.Parent then pcall(function() bg:Destroy() end); nameTagBillboards[m]=nil end end
end

local function toggleNameTags()
    nameTagActive = not nameTagActive
    if nameTagActive then refreshNameTags() else removeAllNameTags() end
end

