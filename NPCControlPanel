-- Helper: slider
local function makeSlider(cfg)
    local cn = Instance.new("Frame")
    cn.Size = UDim2.new(1, -10, 0, 42)
    cn.Position = UDim2.new(0, 5, 0, cfg.y)
    cn.BackgroundTransparency = 1
    cn.ZIndex = 60
    cn.Parent = cfg.p

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 0, 13)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    lbl.TextColor3 = Color3.fromRGB(175, 175, 205)
    lbl.TextSize = 9
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 61
    lbl.Parent = cn

    local track_bg = Instance.new("Frame")
    track_bg.Size = UDim2.new(1, -8, 0, 5)
    track_bg.Position = UDim2.new(0, 4, 0, 20)
    track_bg.BackgroundColor3 = Color3.fromRGB(40, 40, 58)
    track_bg.BorderSizePixel = 0
    track_bg.ZIndex = 61
    track_bg.Parent = cn
    Instance.new("UICorner", track_bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = cfg.fc or Color3.fromRGB(0, 135, 225)
    fill.BorderSizePixel = 0
    fill.ZIndex = 62
    fill.Parent = track_bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.BackgroundColor3 = cfg.kc or Color3.fromRGB(0, 175, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 63
    knob.Parent = track_bg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function applyPct(p)
        p = math.clamp(p, 0, 1)
        local v
        if cfg.step then
            v = math.floor((cfg.min + p * (cfg.max - cfg.min)) / cfg.step + 0.5) * cfg.step
        else
            v = math.floor(cfg.min + p * (cfg.max - cfg.min))
        end
        v = math.clamp(v, cfg.min, cfg.max)
        fill.Size = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, 0, 0.5, 0)
        if cfg.fmt then
            lbl.Text = cfg.l .. " — " .. string.format(cfg.fmt, v)
        else
            lbl.Text = cfg.l .. " — " .. v
        end
        cfg.fn(v)
    end
    applyPct((cfg.def - cfg.min) / (cfg.max - cfg.min))

    local sliding = false
    local function updateMouse()
        applyPct((UIS:GetMouseLocation().X - track_bg.AbsolutePosition.X) / track_bg.AbsoluteSize.X)
    end
    local function beginSlide(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; updateMouse() end
    end
    track(knob.InputBegan:Connect(beginSlide))
    track(track_bg.InputBegan:Connect(beginSlide))
    track(UIS.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then updateMouse() end
    end))
    track(UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end))
end

