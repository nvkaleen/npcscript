local function bringNPCToPos(e, tc, dn)
    local oWS, oJP, oJH = 16, 50, 7.2
    pcall(function()
        e.hrp.Anchored = false
        e.hrp.CFrame = tc
        oWS, oJP, oJH = nukeNPCMovement(e.model, e.hrp, e.hum)
    end)
    if not anchoredNPCs[e.model] then
        anchoredNPCs[e.model] = {hrp=e.hrp, hum=e.hum, name=dn or e.model.Name, origWS=oWS, origJP=oJP, origJH=oJH}
    end
end

local function isNPCAtPos(hrp, tc, th)
    local ok, dist = pcall(function() return (hrp.Position - tc.Position).Magnitude end)
    if ok then return dist <= (th or 2) end
    return false
end

local function unanchorNPC(m)
    local d = anchoredNPCs[m]
    if not d then return end
    pcall(function()
        d.hrp.Anchored = false
        d.hum.PlatformStand = false
        d.hum.WalkSpeed = d.origWS or 16
        d.hum.JumpPower = d.origJP or 50
        d.hum.JumpHeight = d.origJH or 7.2
        pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
    end)
    anchoredNPCs[m] = nil
end

local function unanchorAllNPCs()
    for m, _ in pairs(anchoredNPCs) do unanchorNPC(m) end
    anchoredNPCs = {}
end

local function letNPCMove(m, d)
    pcall(function()
        for _, p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then p.Anchored = false end end
        d.hum.PlatformStand = false
        d.hum.WalkSpeed = d.origWS or 16
        d.hum.JumpPower = d.origJP or 50
        d.hum.JumpHeight = d.origJH or 7.2
        for _, j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled = true end end
        for _, obj in ipairs(m:GetDescendants()) do
            if obj:IsA("BallSocketConstraint") then pcall(function() obj:Destroy() end) end
        end
        pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1)
        pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if d.hrp then d.hrp.Velocity = Vector3.new(0, 5, 0) end
    end)
end

local function letAllNPCsMove()
    local count = 0
    for m, d in pairs(anchoredNPCs) do
        local ex = pcall(function() local _ = d.hrp.Position end)
        if ex and m.Parent then letNPCMove(m, d); count = count + 1 end
    end
    anchoredNPCs = {}
    return count
end

local function freezeNPC(m)
    local hrp = m:FindFirstChild("HumanoidRootPart")
    local hum = m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored = true; hrp.Velocity = Vector3.new(0,0,0) end) end
    if hum then pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0 end) end
end

local function unfreezeNPC(m)
    local hrp = m:FindFirstChild("HumanoidRootPart")
    local hum = m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored = false end) end
    if hum then pcall(function() hum.WalkSpeed = 16; hum.JumpPower = 50 end) end
end

local function isNPCFrozen(m)
    local hrp = m:FindFirstChild("HumanoidRootPart")
    if hrp then local ok, v = pcall(function() return hrp.Anchored end); if ok then return v end end
    return false
end

local function startFollowLoop()
    if followLoopActive then return end
    followLoopActive = true
    task.spawn(function()
        local ep = loopEpoch
        while followLoopActive and ep == loopEpoch do
            local mH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if mH then
                for m, _ in pairs(followingNPCs) do
                    pcall(function()
                        if not m.Parent then followingNPCs[m] = nil; return end
                        local hrp = m:FindFirstChild("HumanoidRootPart")
                        local hum = m:FindFirstChildOfClass("Humanoid")
                        if hrp and hum then
                            local dir = (mH.Position - hrp.Position)
                            local dist = dir.Magnitude
                            if dist > 5 then
                                hrp.CFrame = hrp.CFrame + dir.Unit * math.min(hum.WalkSpeed * 0.03, dist - 3)
                                hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(mH.Position.X, hrp.Position.Y, mH.Position.Z))
                            end
                        end
                    end)
                end
            end
            task.wait(0.03)
        end
    end)
end

local function applyNPCSize(m, sx, sy, sz)
    pcall(function()
        for _, p in ipairs(m:GetDescendants()) do
            if p:IsA("BasePart") then
                pcall(function() p.Size = Vector3.new(p.Size.X * sx, p.Size.Y * sy, p.Size.Z * sz) end)
            end
            if p:IsA("SpecialMesh") or p:IsA("BlockMesh") or p:IsA("CylinderMesh") then
                pcall(function() p.Scale = Vector3.new(p.Scale.X * sx, p.Scale.Y * sy, p.Scale.Z * sz) end)
            end
        end
    end)
end

local function trackDeletedNPC(m)
    local hrp = m:FindFirstChild("HumanoidRootPart")
    local cf = hrp and hrp.CFrame or CFrame.new(0, 5, 0)
    local pp = m.Parent and m.Parent:GetFullName() or "Workspace"
    local ok, clone = pcall(function() return m:Clone() end)
    table.insert(deletedNPCs, {name=m.Name, parentPath=pp, cframe=cf, clone=ok and clone or nil, time=os.clock()})
end

