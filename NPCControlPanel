-- [[ BUTTON MAKER ]]
local function addBtn(text, color, func)
    local b = Instance.new("TextButton")
    b.BackgroundColor3 = color
    b.Text = text
    b.Font = Enum.Font.GothamBold
    b.TextColor3 = Color3.new(1, 1, 1)
    b.TextSize = 11
    b.ZIndex = 15
    b.Parent = scrollFrame
    Instance.new("UICorner", b)
    track(b.MouseButton1Click:Connect(func))
    return b
end

-- [[ ACTIONS ]]
local function reset()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then workspace.CurrentCamera.CameraSubject = hum end
end

addBtn("Kill NPCs Loop", Color3.fromRGB(46, 139, 87), function()
    states.killNPCs = not states.killNPCs
    if states.killNPCs then
        task.spawn(function()
            local ep = loopEpoch
            while states.killNPCs and ep == loopEpoch do
                for _, d in pairs(workspace:GetDescendants()) do
                    if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then d.Health = 0 end
                end
                task.wait(0.5)
            end
        end)
    end
end)

addBtn("Push NPCs Mode", Color3.fromRGB(70, 130, 180), function()
    states.pushNPCs = not states.pushNPCs
    task.spawn(function()
        local ep = loopEpoch
        while states.pushNPCs and ep == loopEpoch do
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, d in pairs(workspace:GetDescendants()) do
                    if d:IsA("Humanoid") and d.Parent ~= player.Character and not Players:GetPlayerFromCharacter(d.Parent) then
                        local tHrp = d.Parent:FindFirstChild("HumanoidRootPart")
                        if tHrp and (tHrp.Position - hrp.Position).Magnitude <= pushRange then
                            tHrp.Velocity = (tHrp.Position - hrp.Position).Unit * pushStrength + Vector3.new(0, 20, 0)
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end)

addBtn("Fling All NPCs", Color3.fromRGB(123, 104, 238), function()
    for _, d in pairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local h = d.Parent:FindFirstChild("HumanoidRootPart")
            if h then h.Velocity = Vector3.new(math.random(-1,1), 1, math.random(-1,1)).Unit * flingStrength end
        end
    end
end)

addBtn("Bring All NPCs", Color3.fromRGB(0, 139, 139), function()
    local h = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if h then
        for _, d in pairs(workspace:GetDescendants()) do
            if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
                local t = d.Parent:FindFirstChild("HumanoidRootPart")
                if t then t.CFrame = h.CFrame * CFrame.new(0,0,-5) t.Velocity = Vector3.new(0,0,0) end
            end
        end
    end
end)

addBtn("NPC Deleter", Color3.fromRGB(218, 165, 32), function()
    for _, d in pairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then d.Parent:Destroy() end
    end
end)

