-- ============================================================
--  LET NPCs MOVE — Full revival: unanchor + restore speed +
--  re-enable Motor6Ds + remove PlatformStand + GettingUp state
--  + re-enable any disabled joints + push them slightly so
--  physics wakes them up
-- ============================================================
local function letNPCMove(data)
    pcall(function()
        -- Unanchor all parts
        for _, part in ipairs(data.model:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
            end
        end
        -- Restore humanoid
        data.hum.PlatformStand = false
        data.hum.WalkSpeed = data.origWS or 16
        data.hum.JumpPower = data.origJP or 50
        data.hum.JumpHeight = data.origJH or 7.2
        -- Re-enable Motor6Ds that were disabled by ragdoll
        for _, j in ipairs(data.model:GetDescendants()) do
            if j:IsA("Motor6D") then
                j.Enabled = true
            end
        end
        -- Remove ragdoll constraints we added
        for _, obj in ipairs(data.model:GetDescendants()) do
            if obj:IsA("BallSocketConstraint") then
                pcall(function() obj:Destroy() end)
            end
        end
        -- Clear ragdoll attribute
        for _, j in ipairs(data.model:GetDescendants()) do
            if j:IsA("Motor6D") then
                pcall(function() j:SetAttribute("_ragdolled", nil) end)
            end
        end
        -- Wake up humanoid
        pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1)
        pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        -- Small push to wake physics
        if data.hrp then
            data.hrp.Velocity = Vector3.new(0, 5, 0)
        end
    end)
end

local function letAllNPCsMove()
    local count = 0
    for uid, data in pairs(anchoredNPCs) do
        local exists = pcall(function() local _ = data.hrp.Position end)
        if exists and data.model.Parent then
            letNPCMove(data)
            count = count + 1
        end
    end
    anchoredNPCs = {}
    return count
end

