    local RH=34; local RP=4; local rows={}

    local function uc()
        local t,s=0,0; for _,d in pairs(rows) do t=t+1; if d.enabled then s=s+1 end end
        cl.Text = "Selected: "..s.." / "..t
    end

    local function cRow(name, key, idx)
        local row = Instance.new("Frame"); row.Size = UDim2.new(1,-10,0,RH)
        row.Position = UDim2.new(0,5,0,5+(idx-1)*(RH+RP))
        row.BackgroundColor3 = Color3.fromRGB(28,28,40); row.BorderSizePixel = 0; row.ZIndex = 82; row.Parent = psc
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

        local nl = Instance.new("TextLabel"); nl.Size = UDim2.new(1,-80,1,0); nl.Position = UDim2.new(0,10,0,0)
        nl.BackgroundTransparency = 1; nl.Text = name; nl.Font = Enum.Font.Gotham
        nl.TextColor3 = Color3.fromRGB(220,220,240); nl.TextSize = 12
        nl.TextXAlignment = Enum.TextXAlignment.Left; nl.TextTruncate = Enum.TextTruncate.AtEnd
        nl.ZIndex = 83; nl.Parent = row

        local en = true; if cfg.filterTable[key] ~= nil then en = cfg.filterTable[key] end
        local tb = Instance.new("TextButton"); tb.Size = UDim2.new(0,64,0,24); tb.Position = UDim2.new(1,-70,0.5,-12)
        tb.BackgroundColor3 = en and Color3.fromRGB(40,140,80) or Color3.fromRGB(100,35,35)
        tb.Text = en and ("✓ "..cfg.onLabel) or ("✗ "..cfg.offLabel)
        tb.Font = Enum.Font.GothamBold; tb.TextColor3 = Color3.new(1,1,1); tb.TextSize = 10
        tb.ZIndex = 84; tb.Parent = row; Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 5)

        local data = {row=row, toggleBtn=tb, enabled=en, key=key}
        rows[key] = data; cfg.filterTable[key] = en

        track(tb.MouseButton1Click:Connect(function()
            data.enabled = not data.enabled; cfg.filterTable[data.key] = data.enabled
            if data.enabled then
                tb.Text = "✓ "..cfg.onLabel; tb.BackgroundColor3 = Color3.fromRGB(40,140,80)
                TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(28,28,40)}):Play()
            else
                tb.Text = "✗ "..cfg.offLabel; tb.BackgroundColor3 = Color3.fromRGB(100,35,35)
                TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3=Color3.fromRGB(35,20,20)}):Play()
            end; uc()
        end))

        row.MouseEnter:Connect(function()
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3=data.enabled and Color3.fromRGB(36,36,55) or Color3.fromRGB(45,25,25)}):Play()
        end)
        row.MouseLeave:Connect(function()
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3=data.enabled and Color3.fromRGB(28,28,40) or Color3.fromRGB(35,20,20)}):Play()
        end)
        return data
    end

    local function refresh()
        for _,d in pairs(rows) do if d.row and d.row.Parent then d.row:Destroy() end end
        rows = {}
        local npcs = allNPCRoots(); local seen,uniq = {},{}
        for _,e in ipairs(npcs) do
            local k = getNPCKey(e.model)
            if not seen[k] then seen[k]=true; table.insert(uniq, {name=e.model.Name, key=k}) end
        end
        table.sort(uniq, function(a,b) return a.name:lower()<b.name:lower() end)
        for i,n in ipairs(uniq) do cRow(n.name, n.key, i) end
        psc.CanvasSize = UDim2.new(0,0,0,5+#uniq*(RH+RP)); uc()
    end

    track(sa.MouseButton1Click:Connect(function()
        for k,d in pairs(rows) do d.enabled=true; cfg.filterTable[k]=true
            d.toggleBtn.Text="✓ "..cfg.onLabel; d.toggleBtn.BackgroundColor3=Color3.fromRGB(40,140,80)
            d.row.BackgroundColor3=Color3.fromRGB(28,28,40)
        end; uc()
    end))
    track(da.MouseButton1Click:Connect(function()
        for k,d in pairs(rows) do d.enabled=false; cfg.filterTable[k]=false
            d.toggleBtn.Text="✗ "..cfg.offLabel; d.toggleBtn.BackgroundColor3=Color3.fromRGB(100,35,35)
            d.row.BackgroundColor3=Color3.fromRGB(35,20,20)
        end; uc()
    end))
    track(pr.MouseButton1Click:Connect(refresh))
    track(pcl.MouseButton1Click:Connect(function() panel.Visible = false end))
    return panel, refresh
end

