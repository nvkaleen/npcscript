local function letNPCMove(model, data)
    pcall(function()
        for _, part in ipairs(model:GetDescendants()) do if part:IsA("BasePart") then part.Anchored = false end end
        data.hum.PlatformStand=false; data.hum.WalkSpeed=data.origWS or 16; data.hum.JumpPower=data.origJP or 50; data.hum.JumpHeight=data.origJH or 7.2
        for _, j in ipairs(model:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled=true end end
        for _, obj in ipairs(model:GetDescendants()) do if obj:IsA("BallSocketConstraint") then pcall(function() obj:Destroy() end) end end
        pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1); pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if data.hrp then data.hrp.Velocity=Vector3.new(0,5,0) end
    end)
end
