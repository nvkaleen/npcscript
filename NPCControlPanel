    cntLbl.TextSize = 8; cntLbl.TextXAlignment = Enum.TextXAlignment.Right
    cntLbl.ZIndex = 82; cntLbl.Parent = cr

    local psc = Instance.new("ScrollingFrame")
    psc.Size = UDim2.new(1, -8, 1, -56); psc.Position = UDim2.new(0, 4, 0, 54)
    psc.BackgroundColor3 = Color3.fromRGB(8, 8, 14); psc.BackgroundTransparency = 0.2
    psc.BorderSizePixel = 0; psc.ScrollBarThickness = 3
    psc.ScrollBarImageColor3 = cfg.ac; psc.CanvasSize = UDim2.new(0, 0, 0, 0)
    psc.ElasticBehavior = Enum.ElasticBehavior.Never; psc.ZIndex = 81; psc.Parent = p
    Instance.new("UICorner", psc).CornerRadius = UDim.new(0, 4)

    local RH = 24; local RP = 2; local rows = {}

    local function uc()
        local t, s = 0, 0
        for _, d in pairs(rows) do t = t + 1; if d.en then s = s + 1 end end
        cntLbl.Text = s .. "/" .. t
    end

    local function cR(dn, ky, ix)
        local rw = Instance.new("Frame")
        rw.Size = UDim2.new(1, -2, 0, RH); rw.Position = UDim2.new(0, 1, 0, 1 + (ix-1)*(RH+RP))
        rw.BackgroundColor3 = Color3.fromRGB(18, 18, 30); rw.BorderSizePixel = 0
        rw.ZIndex = 82; rw.Parent = psc; Instance.new("UICorner", rw).CornerRadius = UDim.new(0, 3)

        local nl = Instance.new("TextLabel")
        nl.Size = UDim2.new(1, -48, 1, 0); nl.Position = UDim2.new(0, 3, 0, 0)
        nl.BackgroundTransparency = 1; nl.Text = dn; nl.Font = Enum.Font.Gotham
        nl.TextColor3 = Color3.fromRGB(192, 192, 212); nl.TextSize = 8
        nl.TextXAlignment = Enum.TextXAlignment.Left; nl.TextTruncate = Enum.TextTruncate.AtEnd
        nl.ZIndex = 83; nl.Parent = rw

        local en = true
        if cfg.ft[ky] ~= nil then en = cfg.ft[ky] end

        local tb = Instance.new("TextButton")
        tb.Size = UDim2.new(0, 40, 0, 16); tb.Position = UDim2.new(1, -44, 0.5, -8)
        tb.BackgroundColor3 = en and Color3.fromRGB(28, 112, 58) or Color3.fromRGB(78, 22, 22)
        tb.Text = en and ("✓ " .. cfg.ol) or ("✗ " .. cfg.ofl)
        tb.Font = Enum.Font.GothamBold; tb.TextColor3 = Color3.new(1,1,1)
        tb.TextSize = 7; tb.ZIndex = 84; tb.Parent = rw
        Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 3)

        local data = {row=rw, tb=tb, en=en, key=ky}
        rows[ky] = data
        cfg.ft[ky] = en

        track(tb.MouseButton1Click:Connect(function()
            data.en = not data.en; cfg.ft[data.key] = data.en
            if data.en then
                tb.Text = "✓ " .. cfg.ol; tb.BackgroundColor3 = Color3.fromRGB(28, 112, 58)
            else
                tb.Text = "✗ " .. cfg.ofl; tb.BackgroundColor3 = Color3.fromRGB(78, 22, 22)
            end
            uc()
        end))
    end

    local function refresh()
        for _, d in pairs(rows) do if d.row and d.row.Parent then d.row:Destroy() end end
        rows = {}
        local npcs = allNPCRoots()
        local named = buildDisplayNames(npcs)
        local seen, uniq = {}, {}
        for _, item in ipairs(named) do
            local k = getNPCKey(item.e.model)
            if not seen[k] then seen[k] = true; table.insert(uniq, {d=item.d, k=k}) end
        end
        table.sort(uniq, function(a, b) return a.d:lower() < b.d:lower() end)
        for i, n in ipairs(uniq) do cR(n.d, n.k, i) end
        psc.CanvasSize = UDim2.new(0, 0, 0, 1 + #uniq * (RH + RP))
        uc()
    end

    track(sa.MouseButton1Click:Connect(function()
        for k, d in pairs(rows) do
            d.en = true; cfg.ft[k] = true
            d.tb.Text = "✓ " .. cfg.ol; d.tb.BackgroundColor3 = Color3.fromRGB(28, 112, 58)
        end; uc()
    end))
    track(da.MouseButton1Click:Connect(function()
        for k, d in pairs(rows) do
            d.en = false; cfg.ft[k] = false
            d.tb.Text = "✗ " .. cfg.ofl; d.tb.BackgroundColor3 = Color3.fromRGB(78, 22, 22)
        end; uc()
    end))
    track(prf.MouseButton1Click:Connect(refresh))
    track(pcl.MouseButton1Click:Connect(function() p.Visible = false end))
    return p, refresh
end

