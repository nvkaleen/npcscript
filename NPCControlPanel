-- NPC Actions
local function nukeMovement(model, hrp, hum)
    pcall(function() for _, o in ipairs(model:GetDescendants()) do
        if o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") or o:IsA("BodyForce") or o:IsA("LinearVelocity") or o:IsA("AlignPosition") or o:IsA("AlignOrientation") or o:IsA("VectorForce") then o:Destroy() end end end)
    pcall(function() for _, o in ipairs(model:GetDescendants()) do if o:IsA("Script") or o:IsA("LocalScript") then pcall(function() o.Disabled = true end) end end end)
    pcall(function() for _, p in ipairs(model:GetDescendants()) do if p:IsA("BasePart") then p.Velocity = Vector3.new(0,0,0); pcall(function() p.AssemblyLinearVelocity = Vector3.new(0,0,0) end) end end end)
    local ws, jp, jh = 16, 50, 7.2
    pcall(function() ws = hum.WalkSpeed end); pcall(function() jp = hum.JumpPower end); pcall(function() jh = hum.JumpHeight end)
    pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0; hum.JumpHeight = 0 end)
    pcall(function() hum.PlatformStand = true end); pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hrp.Anchored = true end)
    return ws, jp, jh
end

local function bringNPC(e, cf, dn)
    local ws, jp, jh = 16, 50, 7.2
    pcall(function() e.hrp.Anchored = false; e.hrp.CFrame = cf; ws, jp, jh = nukeMovement(e.model, e.hrp, e.hum) end)
    if not anchoredNPCs[e.model] then anchoredNPCs[e.model] = {hrp=e.hrp, hum=e.hum, name=dn or e.model.Name, ws=ws, jp=jp, jh=jh} end
end

local function isAtPos(hrp, cf, th) local ok, d = pcall(function() return (hrp.Position - cf.Position).Magnitude end); return ok and d <= (th or 2) end

local function unanchor(m) local d = anchoredNPCs[m]; if not d then return end
    pcall(function() d.hrp.Anchored = false; d.hum.PlatformStand = false; d.hum.WalkSpeed = d.ws or 16; d.hum.JumpPower = d.jp or 50; d.hum.JumpHeight = d.jh or 7.2; pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end)
    anchoredNPCs[m] = nil end
local function unanchorAll() for m in pairs(anchoredNPCs) do unanchor(m) end; anchoredNPCs = {} end

local function letAllMove()
    local c = 0
    for m, d in pairs(anchoredNPCs) do pcall(function()
        if not m.Parent then return end
        for _, p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then p.Anchored = false end end
        d.hum.PlatformStand = false; d.hum.WalkSpeed = d.ws or 16; d.hum.JumpPower = d.jp or 50; d.hum.JumpHeight = d.jh or 7.2
        for _, j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled = true end end
        for _, o in ipairs(m:GetDescendants()) do if o:IsA("BallSocketConstraint") then o:Destroy() end end
        pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1); pcall(function() d.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if d.hrp then d.hrp.Velocity = Vector3.new(0, 5, 0) end; c = c + 1
    end) end; anchoredNPCs = {}; return c
end

local function ragdollNPC(m) local hum = m:FindFirstChildOfClass("Humanoid"); if not hum then return end
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end); pcall(function() hum.PlatformStand = true end)
    pcall(function() for _, j in ipairs(m:GetDescendants()) do if j:IsA("Motor6D") and not j:GetAttribute("_r") then j:SetAttribute("_r", true)
        local a0 = Instance.new("Attachment"); a0.CFrame = j.C0; a0.Parent = j.Part0
        local a1 = Instance.new("Attachment"); a1.CFrame = j.C1; a1.Parent = j.Part1
        local b = Instance.new("BallSocketConstraint"); b.Attachment0 = a0; b.Attachment1 = a1; b.LimitsEnabled = true; b.TwistLimitsEnabled = true; b.UpperAngle = 45; b.TwistLowerAngle = -45; b.TwistUpperAngle = 45; b.Parent = j.Parent; j.Enabled = false end end end)
    local hrp = m:FindFirstChild("HumanoidRootPart"); if hrp then hrp.Velocity = hrp.Velocity + Vector3.new(0, 30, 0) end end

local function freezeNPC(m) local hrp = m:FindFirstChild("HumanoidRootPart"); local hum = m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored = true; hrp.Velocity = Vector3.new(0,0,0) end) end
    if hum then pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0 end) end end
local function unfreezeNPC(m) local hrp = m:FindFirstChild("HumanoidRootPart"); local hum = m:FindFirstChildOfClass("Humanoid")
    if hrp then pcall(function() hrp.Anchored = false end) end; if hum then pcall(function() hum.WalkSpeed = 16; hum.JumpPower = 50 end) end end
local function isFrozen(m) local hrp = m:FindFirstChild("HumanoidRootPart"); if hrp then local ok, v = pcall(function() return hrp.Anchored end); if ok then return v end end; return false end

local function resizeNPC(m, sx, sy, sz) pcall(function() for _, p in ipairs(m:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.Size = Vector3.new(p.Size.X*sx, p.Size.Y*sy, p.Size.Z*sz) end) end end end) end

local function trackDeleted(m) local hrp = m:FindFirstChild("HumanoidRootPart"); local cf = hrp and hrp.CFrame or CFrame.new(0,5,0)
    local ok, clone = pcall(function() return m:Clone() end); table.insert(deletedNPCs, {name=m.Name, cf=cf, clone=ok and clone or nil}) end

local function startFollow() if followActive then return end; followActive = true
    task.spawn(function() local ep = loopEpoch; while followActive and ep == loopEpoch do
        local myH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if myH then for m in pairs(followNPCs) do pcall(function() if not m.Parent then followNPCs[m] = nil; return end
            local hrp = m:FindFirstChild("HumanoidRootPart"); local hum = m:FindFirstChildOfClass("Humanoid")
            if hrp and hum then local dir = myH.Position - hrp.Position; if dir.Magnitude > 5 then
                hrp.CFrame = hrp.CFrame + dir.Unit * math.min(hum.WalkSpeed * 0.03, dir.Magnitude - 3)
                hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(myH.Position.X, hrp.Position.Y, myH.Position.Z)) end end end) end end
        task.wait(0.03) end end) end

