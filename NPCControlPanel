track(mouse.Button1Down:Connect(function()
    local target = mouse.Target; if not target then return end
    if anchorActive and target:IsA("BasePart") then target.Anchored = not target.Anchored; return end

    -- Teleport destination click
    if states.teleportClick and teleportSelectedNPC then
        local dest = mouse.Hit.Position
        pcall(function()
            local hrp = teleportSelectedNPC:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Anchored = false; hrp.CFrame = CFrame.new(dest + Vector3.new(0, 3, 0)); hrp.Velocity = Vector3.new(0,0,0) end
        end)
        teleportSelectedNPC = nil
        btns5["📍 Teleport NPC"].Text = "⏹ 📍 Teleport NPC: ON"
        return
    end

    local md = target:FindFirstAncestorOfClass("Model"); if not md then return end
    local hm = md:FindFirstChildOfClass("Humanoid")
    local hr = md:FindFirstChild("HumanoidRootPart")
    local isN = hm and not Players:GetPlayerFromCharacter(md); if not isN then return end

    if states.viewNPC then
        workspace.CurrentCamera.CameraSubject = hm; viewingNPC = true; viewedHumanoid = hm
        showUV(); uvBtn.Text = "👁 " .. md.Name
    elseif states.killClick then hm.Health = 0
    elseif states.fling and hr then hr.Velocity = Vector3.new(math.random()*2-1, 0.5, math.random()*2-1).Unit * flingStrength
    elseif states.deleteClick then trackDeletedNPC(md); pcall(function() md:Destroy() end); if refreshDeletedList then refreshDeletedList() end
    elseif states.bringClick then
        local mH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if mH and hr then bringNPCToPos({hum=hm, hrp=hr, model=md}, mH.CFrame * CFrame.new(0, 0, -5), md.Name) end
    elseif states.ragdollClick then ragdollNPC(md)
    elseif states.freezeClick then
        if isNPCFrozen(md) then unfreezeNPC(md) else freezeNPC(md) end
    elseif states.teleportClick then
        teleportSelectedNPC = md; btns5["📍 Teleport NPC"].Text = "📍 Click destination..."
    elseif states.followMe then
        if followingNPCs[md] then followingNPCs[md] = nil else followingNPCs[md] = true; startFollowLoop() end
    elseif states.npcSpeedClick then pcall(function() hm.WalkSpeed = npcSpeedValue end)
    elseif states.healthClick then pcall(function() hm.MaxHealth = npcHealthValue; hm.Health = npcHealthValue end)
    elseif states.sizeClick then applyNPCSize(md, npcSizeX, npcSizeY, npcSizeZ)
    elseif states.invisibleClick then
        local vis = true
        pcall(function()
            for _, part in ipairs(md:GetDescendants()) do
                if part:IsA("BasePart") and part.Transparency >= 0.9 then vis = false; break end
            end
        end)
        pcall(function()
            for _, part in ipairs(md:GetDescendants()) do
                if part:IsA("BasePart") then part.Transparency = vis and 1 or 0 end
                if part:IsA("Decal") or part:IsA("Texture") then part.Transparency = vis and 1 or 0 end
            end
        end)
    elseif states.infoClick then showInfoPanel(md)
    elseif states.respawnClick then switchTab(6); if refreshDeletedList then refreshDeletedList() end end
end))

