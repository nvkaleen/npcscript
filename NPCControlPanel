    local ROW_H = 34
    local ROW_PAD = 4
    local rows = {}

    local function updateCount()
        local total, sel = 0, 0
        for _, data in pairs(rows) do total = total + 1; if data.enabled then sel = sel + 1 end end
        countLbl.Text = "Selected: " .. sel .. " / " .. total
    end

    local function createRow(npcName, npcKey, index)
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, -10, 0, ROW_H)
        row.Position = UDim2.new(0, 5, 0, 5 + (index - 1) * (ROW_H + ROW_PAD))
        row.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
        row.BorderSizePixel = 0
        row.ZIndex = 82
        row.Parent = pScroll
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1, -80, 1, 0)
        nameLbl.Position = UDim2.new(0, 10, 0, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = npcName
        nameLbl.Font = Enum.Font.Gotham
        nameLbl.TextColor3 = Color3.fromRGB(220, 220, 240)
        nameLbl.TextSize = 12
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
        nameLbl.ZIndex = 83
        nameLbl.Parent = row

        local enabled = true
        if cfg.filterTable[npcKey] ~= nil then enabled = cfg.filterTable[npcKey] end

        local togBtn = Instance.new("TextButton")
        togBtn.Size = UDim2.new(0, 64, 0, 24)
        togBtn.Position = UDim2.new(1, -70, 0.5, -12)
        togBtn.BackgroundColor3 = enabled and Color3.fromRGB(40, 140, 80) or Color3.fromRGB(100, 35, 35)
        togBtn.Text = enabled and ("✓ " .. cfg.onLabel) or ("✗ " .. cfg.offLabel)
        togBtn.Font = Enum.Font.GothamBold
        togBtn.TextColor3 = Color3.new(1, 1, 1)
        togBtn.TextSize = 10
        togBtn.ZIndex = 84
        togBtn.Parent = row
        Instance.new("UICorner", togBtn).CornerRadius = UDim.new(0, 5)

        local data = { row = row, toggleBtn = togBtn, enabled = enabled, key = npcKey }
        rows[npcKey] = data
        cfg.filterTable[npcKey] = enabled

        track(togBtn.MouseButton1Click:Connect(function()
            data.enabled = not data.enabled
            cfg.filterTable[data.key] = data.enabled
            if data.enabled then
                togBtn.Text = "✓ " .. cfg.onLabel
                togBtn.BackgroundColor3 = Color3.fromRGB(40, 140, 80)
                TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(28, 28, 40)}):Play()
            else
                togBtn.Text = "✗ " .. cfg.offLabel
                togBtn.BackgroundColor3 = Color3.fromRGB(100, 35, 35)
                TweenService:Create(row, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(35, 20, 20)}):Play()
            end
            updateCount()
        end))

        row.MouseEnter:Connect(function()
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = data.enabled and Color3.fromRGB(36, 36, 55) or Color3.fromRGB(45, 25, 25)}):Play()
        end)
        row.MouseLeave:Connect(function()
            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3 = data.enabled and Color3.fromRGB(28, 28, 40) or Color3.fromRGB(35, 20, 20)}):Play()
        end)
        return data
    end

    local function refresh()
        for _, data in pairs(rows) do if data.row and data.row.Parent then data.row:Destroy() end end
        rows = {}
        local npcs = allNPCRoots()
        local seen, unique = {}, {}
        for _, e in ipairs(npcs) do
            local key = getNPCKey(e.model)
            if not seen[key] then seen[key] = true; table.insert(unique, { name = e.model.Name, key = key }) end
        end
        table.sort(unique, function(a, b) return a.name:lower() < b.name:lower() end)
        for i, npc in ipairs(unique) do createRow(npc.name, npc.key, i) end
        pScroll.CanvasSize = UDim2.new(0, 0, 0, 5 + #unique * (ROW_H + ROW_PAD))
        updateCount()
    end

    track(selAll.MouseButton1Click:Connect(function()
        for key, data in pairs(rows) do
            data.enabled = true; cfg.filterTable[key] = true
            data.toggleBtn.Text = "✓ " .. cfg.onLabel; data.toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 140, 80)
            data.row.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
        end; updateCount()
    end))

    track(deselAll.MouseButton1Click:Connect(function()
        for key, data in pairs(rows) do
            data.enabled = false; cfg.filterTable[key] = false
            data.toggleBtn.Text = "✗ " .. cfg.offLabel; data.toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 35, 35)
            data.row.BackgroundColor3 = Color3.fromRGB(35, 20, 20)
        end; updateCount()
    end))

    track(pRefresh.MouseButton1Click:Connect(refresh))
    track(pClose.MouseButton1Click:Connect(function() panel.Visible = false end))
    return panel, refresh
end

