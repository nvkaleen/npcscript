            data.toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 35, 35)
            data.row.BackgroundColor3 = Color3.fromRGB(35, 20, 20)
        end
        updateCount()
    end))

    track(pRefresh.MouseButton1Click:Connect(refresh))
    track(pClose.MouseButton1Click:Connect(function() panel.Visible = false end))

    return panel, refresh
end

