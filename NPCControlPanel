local function cleanup()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    for _, c in ipairs(connections) do
        if typeof(c) == "RBXScriptConnection" and c.Connected then
            c:Disconnect()
        end
    end
    connections = {}
    local function removeFrom(p)
        if p then
            local old = p:FindFirstChild("NPCControlGUI_v7")
            if old then old:Destroy() end
        end
    end
    removeFrom(uiParent)
    pcall(removeFrom, player:FindFirstChild("PlayerGui"))
    pcall(removeFrom, game:GetService("CoreGui"))
end
_G[CONTROL_KEY] = cleanup

local function resetCamera()
    viewingNPC = false
    viewedHumanoid = nil
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then workspace.CurrentCamera.CameraSubject = hum end
    end
end

local function resetStates()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    resetCamera()
end

local function allNPCRoots()
    local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then
                table.insert(list, { hum = d, hrp = hrp, model = d.Parent })
            end
        end
    end
    return list
end

