        bb.StudsOffset = Vector3.new(0, 3, 0); bb.AlwaysOnTop = true
        bb.Adornee = head; bb.Parent = head
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
        lbl.Text = model.Name; lbl.Font = Enum.Font.GothamBold
        lbl.TextColor3 = Color3.fromRGB(255, 255, 200)
        lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        lbl.TextStrokeTransparency = 0.3; lbl.TextScaled = true; lbl.Parent = bb
        nameTagBillboards[model] = bb
    end)
end

local function refreshNameTags()
    if not nameTagActive then return end
    for _, e in ipairs(allNPCRoots()) do createNameTag(e.model) end
    for m, bg in pairs(nameTagBillboards) do
        if not m.Parent then pcall(function() bg:Destroy() end); nameTagBillboards[m] = nil end
    end
end

