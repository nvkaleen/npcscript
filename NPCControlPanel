-- Kill NPCs Loop
track(buttons["Kill NPCs (Loop)"].MouseButton1Click:Connect(function()
    states.killNPCs = not states.killNPCs
    buttons["Kill NPCs (Loop)"].Text = states.killNPCs and "⏹ Kill Loop: ON" or "Kill NPCs (Loop)"
    if states.killNPCs then
        task.spawn(function()
            local ep = loopEpoch
            while states.killNPCs and ep == loopEpoch do
                for _, e in ipairs(allNPCRoots()) do e.hum.Health = 0 end
                task.wait(0.5)
            end
        end)
    end
end))

-- Push NPCs Loop
track(buttons["Push NPCs (Loop)"].MouseButton1Click:Connect(function()
    states.pushNPCs = not states.pushNPCs
    buttons["Push NPCs (Loop)"].Text = states.pushNPCs and "⏹ Push Loop: ON" or "Push NPCs (Loop)"
    if states.pushNPCs then
        task.spawn(function()
            local ep = loopEpoch
            while states.pushNPCs and ep == loopEpoch do
                local char = player.Character
                local myHRP = char and char:FindFirstChild("HumanoidRootPart")
                if myHRP then
                    for _, e in ipairs(allNPCRoots()) do
                        local dist = (e.hrp.Position - myHRP.Position).Magnitude
                        if dist <= pushRange then
                            local dir = (e.hrp.Position - myHRP.Position).Unit
                            e.hrp.Velocity = dir * pushStrength + Vector3.new(0, 20, 0)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
end))

-- Fling All
track(buttons["Fling All NPCs"].MouseButton1Click:Connect(function()
    for _, e in ipairs(allNPCRoots()) do
        local dir = Vector3.new(math.random() * 2 - 1, 0.5, math.random() * 2 - 1).Unit
        e.hrp.Velocity = dir * flingStrength
    end
end))

-- Bring All
track(buttons["Bring All NPCs"].MouseButton1Click:Connect(function()
    local char  = player.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local npcs = allNPCRoots()
    for i, e in ipairs(npcs) do
        local angle  = (i / math.max(1, #npcs)) * math.pi * 2
        local offset = CFrame.new(math.cos(angle) * 4, 0, math.sin(angle) * 4)
        e.hrp.CFrame   = myHRP.CFrame * offset
        e.hrp.Velocity  = Vector3.new(0, 0, 0)
    end
end))

-- Delete All
track(buttons["Delete All NPCs"].MouseButton1Click:Connect(function()
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            d.Parent:Destroy()
        end
    end
end))

-- Click mode toggles (mutual exclusion for click modes)
local clickModes = {
    { label = "View NPC (Click)",  key = "viewNPC"   },
    { label = "Kill NPC (Click)",  key = "killClick" },
    { label = "Fling NPC (Click)", key = "fling"     },
}

for _, mode in ipairs(clickModes) do
    track(buttons[mode.label].MouseButton1Click:Connect(function()
        -- Turn off other click modes
        for _, other in ipairs(clickModes) do
            if other.key ~= mode.key and states[other.key] then
                states[other.key] = false
                buttons[other.label].Text = other.label
            end
        end
        -- Toggle this one
        states[mode.key] = not states[mode.key]
        buttons[mode.label].Text = states[mode.key] and ("⏹ " .. mode.label .. ": ON") or mode.label

        -- If turning off view mode, also unview
        if mode.key == "viewNPC" and not states.viewNPC then
            if viewingNPC then
                unviewNPC()
            end
        end
    end))
end

