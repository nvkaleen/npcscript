local function destroyOldGuis()  
	for _, name in ipairs(GUI_NAMES) do  
		local oldGui = playerGui:FindFirstChild(name)  
		if oldGui then oldGui:Destroy() end  
	end  
end  
  
local function cleanup()  
	loopEpoch = loopEpoch + 1  
	for k in pairs(states) do states[k] = false end  
	anchorActive = false  
	workspace.CurrentCamera.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	for _, conn in ipairs(connections) do  
		if conn.Connected then conn:Disconnect() end  
	end  
	table.clear(connections)  
	if pushRangeVisual then pushRangeVisual:Destroy() pushRangeVisual = nil end  
	destroyOldGuis()  
end  
  
_G[CONTROL_KEY] = cleanup  
