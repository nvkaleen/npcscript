-- NPC Follow
local function startFollowLoop()
    if followLoopActive then return end; followLoopActive=true
    task.spawn(function() local ep=loopEpoch
        while followLoopActive and ep==loopEpoch do
            local mH=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if mH then for model,_ in pairs(followingNPCs) do pcall(function()
                if model.Parent then local hrp=model:FindFirstChild("HumanoidRootPart"); local hum=model:FindFirstChildOfClass("Humanoid")
                    if hrp and hum then local dir=(mH.Position-hrp.Position); local dist=dir.Magnitude
                        if dist>5 then hrp.CFrame=hrp.CFrame+dir.Unit*math.min(hum.WalkSpeed*0.03,dist-3)
                            hrp.CFrame=CFrame.lookAt(hrp.Position,Vector3.new(mH.Position.X,hrp.Position.Y,mH.Position.Z)) end
                    end
                else followingNPCs[model]=nil end
            end) end end
            task.wait(0.03)
        end
    end)
end

local function applyNPCSize(model, sx, sy, sz)
    pcall(function()
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") then pcall(function() part.Size = Vector3.new(part.Size.X*sx, part.Size.Y*sy, part.Size.Z*sz) end) end
        end
        for _, mesh in ipairs(model:GetDescendants()) do
            if mesh:IsA("SpecialMesh") or mesh:IsA("BlockMesh") or mesh:IsA("CylinderMesh") then
                pcall(function() mesh.Scale = Vector3.new(mesh.Scale.X*sx, mesh.Scale.Y*sy, mesh.Scale.Z*sz) end)
            end
        end
    end)
end

