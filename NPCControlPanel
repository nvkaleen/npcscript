local function updateNameTags()
    for key, data in pairs(nameTagObjects) do
        pcall(function()
            if data.hum and data.hum.Parent then
                local hp = data.hum.Health
                local maxHp = data.hum.MaxHealth
                local pct = math.clamp(hp / maxHp, 0, 1)
                data.healthL.Text = math.floor(hp).."/"..math.floor(maxHp)
                data.barFill.Size = UDim2.new(pct, 0, 1, 0)
                if pct > 0.5 then data.barFill.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
                elseif pct > 0.25 then data.barFill.BackgroundColor3 = Color3.fromRGB(220, 180, 40)
                else data.barFill.BackgroundColor3 = Color3.fromRGB(220, 50, 50) end
            end
        end)
    end
end

