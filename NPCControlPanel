local function makeSlider(cfg)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1,-20,0,58); container.Position = UDim2.new(0,10,0,cfg.yOffset)
    container.BackgroundTransparency = 1; container.ZIndex = 60; container.Parent = cfg.parent

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,0,0,22); lbl.BackgroundTransparency = 1; lbl.Font = Enum.Font.Gotham
    lbl.TextColor3 = Color3.fromRGB(200,200,230); lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 61; lbl.Parent = container

    local tbg = Instance.new("Frame")
    tbg.Size = UDim2.new(1,-20,0,8); tbg.Position = UDim2.new(0,10,0,32)
    tbg.BackgroundColor3 = Color3.fromRGB(55,55,75); tbg.BorderSizePixel = 0
    tbg.ZIndex = 61; tbg.Parent = container
    Instance.new("UICorner", tbg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0,0,1,0); fill.BackgroundColor3 = Color3.fromRGB(0,160,255)
    fill.BorderSizePixel = 0; fill.ZIndex = 62; fill.Parent = tbg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,18,0,18); knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.BackgroundColor3 = Color3.fromRGB(0,200,255); knob.BorderSizePixel = 0
    knob.ZIndex = 63; knob.Parent = tbg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function applyPercent(p)
        p = math.clamp(p,0,1)
        local val = math.floor(cfg.min + p*(cfg.max-cfg.min))
        fill.Size = UDim2.new(p,0,1,0); knob.Position = UDim2.new(p,0,0.5,0)
        lbl.Text = cfg.label.."  —  "..tostring(val); cfg.onChange(val)
    end
    applyPercent((cfg.default-cfg.min)/(cfg.max-cfg.min))

    local sliding = false
    local function ufm()
        local mx = UserInputService:GetMouseLocation().X
        applyPercent((mx-tbg.AbsolutePosition.X)/tbg.AbsoluteSize.X)
    end
    local function bs(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; ufm() end end
    track(knob.InputBegan:Connect(bs)); track(tbg.InputBegan:Connect(bs))
    track(UserInputService.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType==Enum.UserInputType.MouseMovement then ufm() end
    end))
    track(UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
    end))
end

