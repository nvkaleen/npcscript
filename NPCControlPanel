local function resetAllUI()
    local allBtns = getAllButtons()
    for _, mode in ipairs(allClickModes) do
        if allBtns[mode.label] then allBtns[mode.label].Text = mode.label end
    end
    for _, def in ipairs(tab1Defs) do
        if buttons[def.label] then buttons[def.label].Text = def.label end
    end
    for label, b3 in pairs(buttons3) do
        b3.btn.Text = "OFF"; b3.dot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    end
end

track(stopBtn.MouseButton1Click:Connect(function() resetStates(); hideUnviewButton(); resetAllUI() end))

track(anchorBtn.MouseButton1Click:Connect(function()
    anchorActive = not anchorActive
    anchorBtn.Text = "Anchor Toggle: " .. (anchorActive and "ON" or "OFF")
    anchorBtn.BackgroundColor3 = anchorActive and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(80, 40, 40)
end))

track(settingsBtn.MouseButton1Click:Connect(function() settingsPanel.Visible = not settingsPanel.Visible end))
track(setCloseBtn.MouseButton1Click:Connect(function() settingsPanel.Visible = false end))

-- ============================================================
--  CLICK HANDLER
-- ============================================================
track(mouse.Button1Down:Connect(function()
    local target = mouse.Target
    if not target then return end
    if anchorActive and target:IsA("BasePart") then target.Anchored = not target.Anchored; return end
    local model = target:FindFirstAncestorOfClass("Model")
    if not model then return end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local isNPC = hum and not Players:GetPlayerFromCharacter(model)
    if not isNPC then return end

    if states.viewNPC then
        workspace.CurrentCamera.CameraSubject = hum; viewingNPC = true; viewedHumanoid = hum
        showUnviewButton(); unviewBtn.Text = "👁 Unview: " .. (model.Name or "NPC")
    elseif states.killClick then hum.Health = 0
    elseif states.fling and hrp then hrp.Velocity = Vector3.new(math.random()*2-1,0.5,math.random()*2-1).Unit * flingStrength
    elseif states.deleteClick then pcall(function() model:Destroy() end)
    elseif states.bringClick then
        local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if myHRP and hrp then hrp.CFrame = myHRP.CFrame * CFrame.new(0,0,-5); hrp.Velocity = Vector3.new(0,0,0) end
    elseif states.ragdollClick then ragdollNPC(model)
    end
end))

task.spawn(function()
    while gui.Parent do
        if viewingNPC and viewedHumanoid then
            local ok = pcall(function() local _ = viewedHumanoid.Health; local _ = viewedHumanoid.Parent end)
            if not ok or not viewedHumanoid.Parent or viewedHumanoid.Health <= 0 then unviewNPC() end
        end; task.wait(0.5)
    end
end)

-- ============================================================
--  HOTKEYS
-- ============================================================
track(UserInputService.InputBegan:Connect(function(inp, gameProcessed)
    if inp.KeyCode == Enum.KeyCode.X and not gameProcessed then resetStates(); hideUnviewButton(); resetAllUI() end
    if inp.KeyCode == Enum.KeyCode.C then setVisible(not guiVisible) end
    if inp.KeyCode == Enum.KeyCode.Insert then setVisible(not guiVisible) end
    if inp.KeyCode == Enum.KeyCode.V and viewingNPC then unviewNPC() end
end))

print("[NPC Control Panel v8] Loaded | 📰 UPD button for changelog | C/Insert = toggle | X = stop | V = unview")
