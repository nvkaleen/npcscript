local function displayNames(list)
    local counts, indices = {}, {}
    for _, e in ipairs(list) do local n = e.model.Name; counts[n] = (counts[n] or 0) + 1 end
    local result = {}
    for _, e in ipairs(list) do local n = e.model.Name
        if counts[n] > 1 then indices[n] = (indices[n] or 0) + 1; table.insert(result, {e=e, name=n.." ("..indices[n]..")"})
        else table.insert(result, {e=e, name=n}) end
