local function setAutoState(label, key, active)
    states[key] = active
    local b3 = buttons3[label]
    if b3 then
        b3.btn.Text = active and "⏹ ON" or "OFF"
        b3.dot.BackgroundColor3 = active and Color3.fromRGB(0, 255, 80) or Color3.fromRGB(80, 80, 80)
        if active then
            task.spawn(function()
                while states[key] do
                    TweenService:Create(b3.dot, TweenInfo.new(0.4), {BackgroundColor3 = Color3.fromRGB(0, 255, 80)}):Play()
                    task.wait(0.4)
                    if not states[key] then break end
                    TweenService:Create(b3.dot, TweenInfo.new(0.4), {BackgroundColor3 = Color3.fromRGB(0, 150, 40)}):Play()
                    task.wait(0.4)
                end
                b3.dot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
            end)
        end
    end
end

