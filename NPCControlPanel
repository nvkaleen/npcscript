track(mouse.Button1Down:Connect(function()
    local target = mouse.Target; if not target then return end
    if anchorActive and target:IsA("BasePart") then target.Anchored = not target.Anchored; return end
    local model = target:FindFirstAncestorOfClass("Model"); if not model then return end
    local hum = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local isNPC = hum and not Players:GetPlayerFromCharacter(model)
    if not isNPC then return end

    if states.viewNPC then
        workspace.CurrentCamera.CameraSubject = hum; viewingNPC=true; viewedHumanoid=hum
        showUnviewButton(); unviewBtn.Text = "👁 Unview: "..(model.Name or "NPC")
    elseif states.killClick then hum.Health = 0
    elseif states.fling and hrp then hrp.Velocity = Vector3.new(math.random()*2-1,0.5,math.random()*2-1).Unit*flingStrength
    elseif states.deleteClick then pcall(function() model:Destroy() end)
    elseif states.bringClick then
        local myH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if myH and hrp then
            bringNPCToPos({hum=hum, hrp=hrp, model=model}, myH.CFrame * CFrame.new(0,0,-5))
        end
    elseif states.ragdollClick then ragdollNPC(model)
    end
end))

task.spawn(function()
    while gui.Parent do
