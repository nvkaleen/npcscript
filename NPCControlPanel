local function bringNPCToPos(e, targetCFrame, displayName)
    local oWS, oJP, oJH = 16, 50, 7.2
    pcall(function() e.hrp.Anchored=false; e.hrp.CFrame=targetCFrame; oWS,oJP,oJH=nukeNPCMovement(e.model,e.hrp,e.hum) end)
    if not anchoredNPCs[e.model] then
        anchoredNPCs[e.model] = {hrp=e.hrp, hum=e.hum, name=displayName or e.model.Name, origWS=oWS, origJP=oJP, origJH=oJH}
    end
end

local function isNPCAtPos(hrp, targetCFrame, threshold)
    local ok, dist = pcall(function() return (hrp.Position - targetCFrame.Position).Magnitude end)
    if ok then return dist <= (threshold or 2) end; return false
end

local function unanchorNPC(model) local data=anchoredNPCs[model]; if not data then return end
    pcall(function() data.hrp.Anchored=false; data.hum.PlatformStand=false; data.hum.WalkSpeed=data.origWS or 16; data.hum.JumpPower=data.origJP or 50; data.hum.JumpHeight=data.origJH or 7.2; pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end) end)
    anchoredNPCs[model]=nil end
local function unanchorAllNPCs() for m,_ in pairs(anchoredNPCs) do unanchorNPC(m) end; anchoredNPCs={} end

local function letNPCMove(model, data)
    pcall(function()
        for _, part in ipairs(model:GetDescendants()) do if part:IsA("BasePart") then part.Anchored = false end end
        data.hum.PlatformStand=false; data.hum.WalkSpeed=data.origWS or 16; data.hum.JumpPower=data.origJP or 50; data.hum.JumpHeight=data.origJH or 7.2
        for _, j in ipairs(model:GetDescendants()) do if j:IsA("Motor6D") then j.Enabled=true end end
        for _, obj in ipairs(model:GetDescendants()) do if obj:IsA("BallSocketConstraint") then pcall(function() obj:Destroy() end) end end
        pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        task.wait(0.1); pcall(function() data.hum:ChangeState(Enum.HumanoidStateType.Running) end)
        if data.hrp then data.hrp.Velocity=Vector3.new(0,5,0) end
    end)
end
local function letAllNPCsMove()
    local count=0; for model,data in pairs(anchoredNPCs) do
        local ex=pcall(function() local _=data.hrp.Position end)
        if ex and model.Parent then letNPCMove(model,data); count=count+1 end end
    anchoredNPCs={}; return count end

