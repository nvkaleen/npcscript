-- NPC Utils
local function allNPCs()
    local l = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local h = d.Parent:FindFirstChild("HumanoidRootPart")
            if h then table.insert(l, {hum=d, hrp=h, model=d.Parent}) end
        end
    end
    return l
end

local function npcsInRange(range)
    local myH = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myH then return {} end
    local pos = myH.Position; local l = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local h = d.Parent:FindFirstChild("HumanoidRootPart")
            if h then local ok, dist = pcall(function() return (h.Position - pos).Magnitude end)
                if ok and dist <= range then table.insert(l, {hum=d, hrp=h, model=d.Parent}) end end
        end
    end
    return l
end

