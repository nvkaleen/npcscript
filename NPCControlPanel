        if buttons[def.label] then buttons[def.label].Text = def.label end
    end
end))

-- Anchor Toggle
track(anchorBtn.MouseButton1Click:Connect(function()
    anchorActive = not anchorActive
    anchorBtn.Text             = "Anchor Toggle: " .. (anchorActive and "ON" or "OFF")
    anchorBtn.BackgroundColor3 = anchorActive and Color3.fromRGB(0, 120, 60) or Color3.fromRGB(80, 40, 40)
end))

-- Settings open/close
track(settingsBtn.MouseButton1Click:Connect(function()
    settingsPanel.Visible = not settingsPanel.Visible
end))
track(setCloseBtn.MouseButton1Click:Connect(function()
    settingsPanel.Visible = false
end))

-- ============================================================
--  CLICK HANDLER
-- ============================================================
track(mouse.Button1Down:Connect(function()
    local target = mouse.Target
    if not target then return end

    -- Anchor toggle
    if anchorActive and target:IsA("BasePart") then
        target.Anchored = not target.Anchored
        return
    end

    local model = target:FindFirstAncestorOfClass("Model")
    if not model then return end
    local hum   = model:FindFirstChildOfClass("Humanoid")
    local hrp   = model:FindFirstChild("HumanoidRootPart")
    local isNPC = hum and not Players:GetPlayerFromCharacter(model)

    if not isNPC then return end

    if states.viewNPC then
        -- Lock camera to this NPC
        workspace.CurrentCamera.CameraSubject = hum
        viewingNPC     = true
        viewedHumanoid = hum
        showUnviewButton()

        -- Update unview button text with NPC name
        local npcName = model.Name or "NPC"
        unviewBtn.Text = "👁 Unview: " .. npcName

    elseif states.killClick then
        hum.Health = 0

    elseif states.fling and hrp then
        local dir = Vector3.new(math.random() * 2 - 1, 0.5, math.random() * 2 - 1).Unit
        hrp.Velocity = dir * flingStrength
    end
end))

-- Monitor viewed NPC: if it dies or gets removed, auto-unview
task.spawn(function()
    while gui.Parent do
        if viewingNPC and viewedHumanoid then
            -- Check if humanoid still exists and is alive
            local ok = pcall(function()
                local _ = viewedHumanoid.Health
                local _ = viewedHumanoid.Parent
            end)
            if not ok or not viewedHumanoid.Parent or viewedHumanoid.Health <= 0 then
                unviewNPC()
            end
        end
        task.wait(0.5)
    end
end)

-- ============================================================
--  HOTKEYS
-- ============================================================
track(UserInputService.InputBegan:Connect(function(inp, gameProcessed)
    if inp.KeyCode == Enum.KeyCode.X and not gameProcessed then
        resetStates()
        hideUnviewButton()
        for _, def in ipairs(buttonDefs) do
            if buttons[def.label] then buttons[def.label].Text = def.label end
        end
    end

    if inp.KeyCode == Enum.KeyCode.C then
        setVisible(not guiVisible)
    end

    if inp.KeyCode == Enum.KeyCode.Insert then
        setVisible(not guiVisible)
    end

    -- V key = quick unview
    if inp.KeyCode == Enum.KeyCode.V and viewingNPC then
        unviewNPC()
    end
end))

print("[NPC Control Panel v5] Loaded | C/Insert = show/hide | X = stop all | V = unview NPC")
