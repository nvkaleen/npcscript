-- Helper: slider
local function makeSlider(cfg)
    local cn=Instance.new("Frame"); cn.Size=UDim2.new(1,-12,0,44); cn.Position=UDim2.new(0,6,0,cfg.yOffset)
    cn.BackgroundTransparency=1; cn.ZIndex=60; cn.Parent=cfg.parent
    local lb=Instance.new("TextLabel"); lb.Size=UDim2.new(1,0,0,14); lb.BackgroundTransparency=1; lb.Font=Enum.Font.Gotham
    lb.TextColor3=Color3.fromRGB(180,180,210); lb.TextSize=10; lb.TextXAlignment=Enum.TextXAlignment.Left; lb.ZIndex=61; lb.Parent=cn
    local tb=Instance.new("Frame"); tb.Size=UDim2.new(1,-10,0,6); tb.Position=UDim2.new(0,5,0,22)
    tb.BackgroundColor3=Color3.fromRGB(42,42,60); tb.BorderSizePixel=0; tb.ZIndex=61; tb.Parent=cn; Instance.new("UICorner",tb).CornerRadius=UDim.new(1,0)
    local fl=Instance.new("Frame"); fl.Size=UDim2.new(0,0,1,0); fl.BackgroundColor3=cfg.fc or Color3.fromRGB(0,140,230)
    fl.BorderSizePixel=0; fl.ZIndex=62; fl.Parent=tb; Instance.new("UICorner",fl).CornerRadius=UDim.new(1,0)
    local kn=Instance.new("Frame"); kn.Size=UDim2.new(0,13,0,13); kn.AnchorPoint=Vector2.new(0.5,0.5)
    kn.BackgroundColor3=cfg.kc or Color3.fromRGB(0,180,255); kn.BorderSizePixel=0; kn.ZIndex=63; kn.Parent=tb; Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local function ap(p) p=math.clamp(p,0,1)
        local v
        if cfg.step then v=math.floor((cfg.min+p*(cfg.max-cfg.min))/cfg.step+0.5)*cfg.step
        else v=math.floor(cfg.min+p*(cfg.max-cfg.min)) end
        v=math.clamp(v,cfg.min,cfg.max)
        fl.Size=UDim2.new(p,0,1,0); kn.Position=UDim2.new(p,0,0.5,0)
        if cfg.fmt then lb.Text=cfg.label.." — "..string.format(cfg.fmt, v) else lb.Text=cfg.label.." — "..v end
        cfg.onChange(v) end
    ap((cfg.default-cfg.min)/(cfg.max-cfg.min))
    local sl=false
    local function um() ap((UserInputService:GetMouseLocation().X-tb.AbsolutePosition.X)/tb.AbsoluteSize.X) end
    track(kn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=true; um() end end))
    track(tb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=true; um() end end))
    track(UserInputService.InputChanged:Connect(function(i) if sl and i.UserInputType==Enum.UserInputType.MouseMovement then um() end end))
    track(UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=false end end))
end

