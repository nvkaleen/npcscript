local function ragdollNPC(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Ragdoll) end)
    pcall(function() hum.PlatformStand = true end)
    pcall(function()
        for _, joint in ipairs(model:GetDescendants()) do
            if joint:IsA("Motor6D") and not joint:GetAttribute("_ragdolled") then
                joint:SetAttribute("_ragdolled", true)
                local att0 = Instance.new("Attachment")
                att0.CFrame = joint.C0; att0.Parent = joint.Part0
                local att1 = Instance.new("Attachment")
                att1.CFrame = joint.C1; att1.Parent = joint.Part1
                local bsc = Instance.new("BallSocketConstraint")
                bsc.Attachment0 = att0; bsc.Attachment1 = att1
                bsc.LimitsEnabled = true; bsc.TwistLimitsEnabled = true
                bsc.UpperAngle = 45; bsc.TwistLowerAngle = -45; bsc.TwistUpperAngle = 45
                bsc.Parent = joint.Parent; joint.Enabled = false
            end
        end
    end)
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Velocity = hrp.Velocity + Vector3.new(0, 30, 0) end
end

-- ============================================================
--  NUCLEAR BRING — completely locks NPC in place
--  Removes ALL movers, scripts, anchors, zeros everything
-- ============================================================
local function nukeNPCMovement(model, hrp, hum)
    -- 1) Remove ALL body movers and constraints that move the NPC
    pcall(function()
        for _, obj in ipairs(model:GetDescendants()) do
            if obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro")
                or obj:IsA("BodyForce") or obj:IsA("BodyThrust") or obj:IsA("BodyAngularVelocity")
                or obj:IsA("LinearVelocity") or obj:IsA("AlignPosition") or obj:IsA("AlignOrientation")
                or obj:IsA("VectorForce") or obj:IsA("LineForce") or obj:IsA("Torque") then
                obj:Destroy()
            end
        end
    end)

    -- 2) Kill ALL scripts inside the NPC model so nothing can fight back
    pcall(function()
        for _, obj in ipairs(model:GetDescendants()) do
            if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
                pcall(function() obj.Disabled = true end)
                pcall(function() obj:Destroy() end)
            end
        end
    end)

    -- 3) Zero all velocities on every part
    pcall(function()
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") then
                pcall(function() part.Velocity = Vector3.new(0,0,0) end)
                pcall(function() part.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
                pcall(function() part.AssemblyAngularVelocity = Vector3.new(0,0,0) end)
            end
        end
    end)

    -- 4) Freeze humanoid movement completely
    pcall(function()
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        hum.JumpHeight = 0
    end)
    pcall(function() hum.PlatformStand = true end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)

    -- 5) Anchor the HRP so physics can't move it
    pcall(function() hrp.Anchored = true end)

    -- 6) Remove any Welds/Constraints that might be connecting to external parts
    pcall(function()
        for _, obj in ipairs(hrp:GetChildren()) do
            if obj:IsA("Weld") or obj:IsA("WeldConstraint") then
                local p0 = obj:IsA("Weld") and obj.Part0 or nil
                local p1 = obj:IsA("Weld") and obj.Part1 or nil
                -- Only destroy welds to parts OUTSIDE the model
                if p0 and not p0:IsDescendantOf(model) then obj:Destroy()
                elseif p1 and not p1:IsDescendantOf(model) then obj:Destroy() end
            end
        end
    end)
end

local function bringNPCToPos(e, targetCFrame)
    pcall(function()
        -- Unanchor temporarily to set CFrame
        e.hrp.Anchored = false
        -- Set position
        e.hrp.CFrame = targetCFrame
        -- Nuke all movement
        nukeNPCMovement(e.model, e.hrp, e.hum)
    end)
end

-- Check if NPC is close enough to target (considered "locked")
local function isNPCAtPos(hrp, targetCFrame, threshold)
    local ok, dist = pcall(function()
        return (hrp.Position - targetCFrame.Position).Magnitude
    end)
    if ok then return dist <= (threshold or 2) end
    return false
end

