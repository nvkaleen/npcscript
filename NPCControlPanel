    killNPCs = false, pushNPCs = false, nk = false,
    freeze = false, killClick = false, fling = false,
    objDel = false, autoFling = false, viewNPC = false
}
local anchorActive = false
local loopEpoch = 0
local pushStrength = 150
local pushRange = 15
local flingStrength = 300
local pushRangeVisual = nil

local function cleanup()
    loopEpoch = loopEpoch + 1
    for k in pairs(states) do states[k] = false end
    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        workspace.CurrentCamera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid")
    end
    for _, conn in ipairs(connections) do if conn.Connected then conn:Disconnect() end end
    if pushRangeVisual then pushRangeVisual:Destroy() end
    local old = playerGui:FindFirstChild("NPCControlGUICeraulean")
    if old then old:Destroy() end
end
_G[CONTROL_KEY] = cleanup

