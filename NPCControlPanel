local function refreshInfoList()
    -- Clear old rows
    for _,child in ipairs(s7:GetChildren()) do if child:IsA("Frame") and child.Name=="InfoRow" then child:Destroy() end end
    local npcs=allNPCRoots(); local named=buildDisplayNames(npcs)
    local seen={}; local uniq={}
    for _,item in ipairs(named) do local k=getNPCKey(item.e.model); if not seen[k] then seen[k]=true; table.insert(uniq,{e=item.e,d=item.d}) end end
    table.sort(uniq,function(a,b) return a.d:lower()<b.d:lower() end)
    for i,npc in ipairs(uniq) do
        local row=Instance.new("Frame"); row.Name="InfoRow"; row.Size=UDim2.new(1,-4,0,28); row.Position=UDim2.new(0,2,0,22+(i-1)*32); row.BackgroundColor3=Color3.fromRGB(18,22,30); row.BorderSizePixel=0; row.ZIndex=4; row.Parent=s7; Instance.new("UICorner",row).CornerRadius=UDim.new(0,4)
        local nL=Instance.new("TextLabel"); nL.Size=UDim2.new(0.35,0,1,0); nL.Position=UDim2.new(0,4,0,0); nL.BackgroundTransparency=1; nL.Text=npc.d; nL.Font=Enum.Font.GothamBold; nL.TextColor3=Color3.fromRGB(200,220,240); nL.TextSize=8; nL.TextXAlignment=Enum.TextXAlignment.Left; nL.TextTruncate=Enum.TextTruncate.AtEnd; nL.ZIndex=5; nL.Parent=row
        local infoLbl=Instance.new("TextLabel"); infoLbl.Size=UDim2.new(0.65,-4,1,0); infoLbl.Position=UDim2.new(0.35,0,0,0); infoLbl.BackgroundTransparency=1; infoLbl.Font=Enum.Font.Gotham; infoLbl.TextColor3=Color3.fromRGB(150,180,200); infoLbl.TextSize=8; infoLbl.TextXAlignment=Enum.TextXAlignment.Left; infoLbl.ZIndex=5; infoLbl.Parent=row
        local function updateInfo()
            pcall(function()
                local hum=npc.e.hum; local hrp=npc.e.hrp
                local myH=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local dist=myH and math.floor((hrp.Position-myH.Position).Magnitude) or "?"
                local hp=math.floor(hum.Health); local maxhp=math.floor(hum.MaxHealth); local spd=math.floor(hum.WalkSpeed)
                infoLbl.Text=string.format("HP:%d/%d SPD:%d D:%s",hp,maxhp,spd,tostring(dist))
            end)
        end
        updateInfo()
        -- Live update
        local conn; conn=RS.RenderStepped:Connect(function() if not npc.e.model.Parent then conn:Disconnect(); return end; pcall(updateInfo) end)
    end
    s7.CanvasSize=UDim2.new(0,0,0,22+#uniq*32+6)
end
