local function allNPCRoots()
    local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then
                table.insert(list, {hum=d, hrp=hrp, model=d.Parent})
            end
        end
    end
    return list
end

local function allNPCRootsInRange(range)
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return {} end
    local myPos = myHRP.Position
    local list = {}
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            local hrp = d.Parent:FindFirstChild("HumanoidRootPart")
            if hrp then
                local ok, dist = pcall(function() return (hrp.Position - myPos).Magnitude end)
                if ok and dist <= range then
                    table.insert(list, {hum=d, hrp=hrp, model=d.Parent})
                end
            end
        end
    end
    return list
end

local function getNPCKey(m) return m:GetFullName() end

local function buildDisplayNames(nl)
    local nc, ni = {}, {}
    for _, e in ipairs(nl) do local n = e.model.Name; nc[n] = (nc[n] or 0) + 1 end
    local result = {}
    for _, e in ipairs(nl) do
        local n = e.model.Name
        if nc[n] > 1 then
            ni[n] = (ni[n] or 0) + 1
            table.insert(result, {e=e, d=n.." ("..ni[n]..")"})
        else
            table.insert(result, {e=e, d=n})
        end
    end
    return result
end

local function ragdollNPC(m)
    local hum = m:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Ragdoll) end)
    pcall(function() hum.PlatformStand = true end)
    pcall(function()
        for _, j in ipairs(m:GetDescendants()) do
            if j:IsA("Motor6D") and not j:GetAttribute("_rag") then
                j:SetAttribute("_rag", true)
                local a0 = Instance.new("Attachment"); a0.CFrame = j.C0; a0.Parent = j.Part0
                local a1 = Instance.new("Attachment"); a1.CFrame = j.C1; a1.Parent = j.Part1
                local b = Instance.new("BallSocketConstraint")
                b.Attachment0 = a0; b.Attachment1 = a1
                b.LimitsEnabled = true; b.TwistLimitsEnabled = true
                b.UpperAngle = 45; b.TwistLowerAngle = -45; b.TwistUpperAngle = 45
                b.Parent = j.Parent; j.Enabled = false
            end
        end
    end)
    local hrp = m:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Velocity = hrp.Velocity + Vector3.new(0, 30, 0) end
end

local function nukeNPCMovement(m, hrp, hum)
    pcall(function()
        for _, obj in ipairs(m:GetDescendants()) do
            if obj:IsA("BodyVelocity") or obj:IsA("BodyPosition") or obj:IsA("BodyGyro")
                or obj:IsA("BodyForce") or obj:IsA("BodyThrust") or obj:IsA("BodyAngularVelocity")
                or obj:IsA("LinearVelocity") or obj:IsA("AlignPosition") or obj:IsA("AlignOrientation")
                or obj:IsA("VectorForce") or obj:IsA("LineForce") or obj:IsA("Torque") then
                obj:Destroy()
            end
        end
    end)
    pcall(function()
        for _, obj in ipairs(m:GetDescendants()) do
            if obj:IsA("Script") or obj:IsA("LocalScript") then
                pcall(function() obj.Disabled = true end)
            end
        end
    end)
    pcall(function()
        for _, part in ipairs(m:GetDescendants()) do
            if part:IsA("BasePart") then
                pcall(function() part.Velocity = Vector3.new(0,0,0) end)
                pcall(function() part.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
            end
        end
    end)
    local oWS, oJP, oJH = 16, 50, 7.2
    pcall(function() oWS = hum.WalkSpeed end)
    pcall(function() oJP = hum.JumpPower end)
    pcall(function() oJH = hum.JumpHeight end)
    pcall(function() hum.WalkSpeed = 0; hum.JumpPower = 0; hum.JumpHeight = 0 end)
    pcall(function() hum.PlatformStand = true end)
    pcall(function() hum:ChangeState(Enum.HumanoidStateType.Physics) end)
    pcall(function() hrp.Anchored = true end)
    return oWS, oJP, oJH
end

