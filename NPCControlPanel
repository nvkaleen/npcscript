    l.TextXAlignment = Enum.TextXAlignment.Left; l.ZIndex = 61; l.Parent = c
    local tb = Instance.new("Frame"); tb.Size = UDim2.new(1,-20,0,8); tb.Position = UDim2.new(0,10,0,32)
    tb.BackgroundColor3 = Color3.fromRGB(55,55,75); tb.BorderSizePixel = 0; tb.ZIndex = 61; tb.Parent = c
    Instance.new("UICorner", tb).CornerRadius = UDim.new(1, 0)
    local f = Instance.new("Frame"); f.Size = UDim2.new(0,0,1,0); f.BackgroundColor3 = Color3.fromRGB(0,160,255)
    f.BorderSizePixel = 0; f.ZIndex = 62; f.Parent = tb; Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    local k = Instance.new("Frame"); k.Size = UDim2.new(0,18,0,18); k.AnchorPoint = Vector2.new(0.5,0.5)
    k.BackgroundColor3 = Color3.fromRGB(0,200,255); k.BorderSizePixel = 0; k.ZIndex = 63; k.Parent = tb
    Instance.new("UICorner", k).CornerRadius = UDim.new(1, 0)
    local function ap(p) p=math.clamp(p,0,1); local v=math.floor(cfg.min+p*(cfg.max-cfg.min))
        f.Size=UDim2.new(p,0,1,0); k.Position=UDim2.new(p,0,0.5,0); l.Text=cfg.label.."  —  "..v; cfg.onChange(v) end
    ap((cfg.default-cfg.min)/(cfg.max-cfg.min))
    local sl=false
    local function um() ap((UserInputService:GetMouseLocation().X-tb.AbsolutePosition.X)/tb.AbsoluteSize.X) end
    local function bs(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then sl=true; um() end end
    track(k.InputBegan:Connect(bs)); track(tb.InputBegan:Connect(bs))
    track(UserInputService.InputChanged:Connect(function(inp) if sl and inp.UserInputType==Enum.UserInputType.MouseMovement then um() end end))
    track(UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then sl=false end end))
end

