track(buttons["Bring All NPCs"].MouseButton1Click:Connect(function()
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local btn = buttons["Bring All NPCs"]
    btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    task.spawn(function()
        for attempt = 1, bringAttempts do
            btn.Text = "Bringing... (" .. attempt .. "/" .. bringAttempts .. ")"
            local filtered = {}
            for _, e in ipairs(allNPCRoots()) do
                local key = getNPCKey(e.model)
                if next(bringFilter) == nil or bringFilter[key] ~= false then
                    table.insert(filtered, e)
                end
            end
            for i, e in ipairs(filtered) do
                local angle = (i / math.max(1, #filtered)) * math.pi * 2
                pcall(function()
                    e.hrp.CFrame = myHRP.CFrame * CFrame.new(math.cos(angle) * 4, 0, math.sin(angle) * 4)
                    e.hrp.Velocity = Vector3.new(0, 0, 0)
                end)
            end
            if attempt < bringAttempts then task.wait(0.1) end
        end
        btn.Text = "Bring All NPCs"; btn.BackgroundColor3 = Color3.fromRGB(0, 139, 139)
    end)
end))

