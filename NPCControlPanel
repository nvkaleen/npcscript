-- [[ INPUTS ]]
track(mouse.Button1Down:Connect(function()
    local target = mouse.Target
    if not target then return end
    local model = target:FindFirstAncestorOfClass("Model")
    local hum = model and model:FindFirstChildOfClass("Humanoid")
    local isNPC = hum and not Players:GetPlayerFromCharacter(model)

    if states.viewNPC and isNPC then workspace.CurrentCamera.CameraSubject = hum
    elseif states.killClick and hum then hum.Health = 0
    elseif states.fling and isNPC then
        local r = model:FindFirstChild("HumanoidRootPart")
        if r then r.Velocity = Vector3.new(math.random(-1,1), 1, math.random(-1,1)).Unit * flingStrength end
    elseif anchorActive and target:IsA("BasePart") then target.Anchored = not target.Anchored end
end))

track(gearBtn.MouseButton1Click:Connect(function() 
    settingsPanel.Visible = not settingsPanel.Visible 
end))

track(UserInputService.InputBegan:Connect(function(i, g)
    if not g then
        if i.KeyCode == Enum.KeyCode.X then reset()
        elseif i.KeyCode == Enum.KeyCode.Insert or i.KeyCode == Enum.KeyCode.C then mainFrame.Visible = not mainFrame.Visible end
    end
end))

