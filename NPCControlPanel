local function getAllButtons()
    local all = {}
    for k, v in pairs(buttons) do all[k] = v end
    for k, v in pairs(buttons2) do all[k] = v end
    return all
end

local function disableAllClickModes(exceptKey)
    local allBtns = getAllButtons()
    for _, mode in ipairs(allClickModes) do
        if mode.key ~= exceptKey and states[mode.key] then
            states[mode.key] = false
            if allBtns[mode.label] then allBtns[mode.label].Text = mode.label end
        end
    end
end

