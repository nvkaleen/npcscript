        local npcs = allNPCRoots()
        local seen = {}
        local unique = {}
        for _, e in ipairs(npcs) do
            local key = getNPCKey(e.model)
            if not seen[key] then
                seen[key] = true
                table.insert(unique, { name = e.model.Name, key = key })
            end
        end
        table.sort(unique, function(a, b) return a.name:lower() < b.name:lower() end)

        for i, npc in ipairs(unique) do
            createRow(npc.name, npc.key, i)
        end
        pScroll.CanvasSize = UDim2.new(0, 0, 0, 5 + #unique * (ROW_H + ROW_PAD))
