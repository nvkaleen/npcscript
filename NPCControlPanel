-- ============================================================
local function ragdollNPC(model)
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    -- Method 1: Set humanoid state
    pcall(function()
        hum:ChangeState(Enum.HumanoidStateType.Physics)
    end)
    pcall(function()
        hum:ChangeState(Enum.HumanoidStateType.Ragdoll)
    end)

    -- Method 2: Set PlatformStand (classic ragdoll)
    pcall(function()
        hum.PlatformStand = true
    end)

    -- Method 3: Break joints and replace with BallSocketConstraints
    pcall(function()
        for _, joint in ipairs(model:GetDescendants()) do
            if joint:IsA("Motor6D") then
                local att0 = Instance.new("Attachment")
                att0.CFrame = joint.C0
                att0.Parent = joint.Part0

                local att1 = Instance.new("Attachment")
                att1.CFrame = joint.C1
                att1.Parent = joint.Part1

                local bsc = Instance.new("BallSocketConstraint")
                bsc.Attachment0 = att0
                bsc.Attachment1 = att1
                bsc.LimitsEnabled = true
                bsc.TwistLimitsEnabled = true
                bsc.UpperAngle = 45
                bsc.TwistLowerAngle = -45
                bsc.TwistUpperAngle = 45
                bsc.Parent = joint.Parent

                joint.Enabled = false
            end
        end
    end)

    -- Give a small upward pop so ragdoll is visible
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Velocity = hrp.Velocity + Vector3.new(0, 30, 0)
    end
end

