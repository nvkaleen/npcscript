local function setVisualizerActive(active)  
	if active then  
		pushRangeVisual.Parent = workspace.CurrentCamera  
		if not visualizerConn then  
			visualizerConn = track(RunService.RenderStepped:Connect(function()  
				local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")  
				if hrp then  
					pushRangeVisual.CFrame = hrp.CFrame  
					pushRangeVisual.Size = Vector3.new(pushRange * 2, pushRange * 2, pushRange * 2)  
				else  
					pushRangeVisual.CFrame = CFrame.new(0, -999, 0)  
				end  
			end))  
		end  
	else  
		pushRangeVisual.Parent = nil  
		if visualizerConn then visualizerConn:Disconnect() visualizerConn = nil end  
	end  
end  
  
